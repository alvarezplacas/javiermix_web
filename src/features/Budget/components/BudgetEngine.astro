---
// Motor de Presupuesto "SmartFlow" - Mobile First & Premium Edition
---

<div class="max-w-4xl mx-auto" id="smart-flow-engine">
    
    <!-- STEP 1: SHEET CONFIGURATION -->
    <div id="step-setup" class="bg-white/10 backdrop-blur-xl border border-white/20 rounded-3xl p-8 shadow-2xl animate-in fade-in zoom-in duration-500">
        <div class="text-center mb-8">
            <h2 class="text-3xl font-black text-white mb-2 tracking-tighter uppercase">Configuración de Placa</h2>
            <p class="text-white/60 text-sm">Define el material base antes de cargar los cortes</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-4">
                <div>
                    <label class="block text-[10px] font-bold text-white/40 uppercase mb-2 ml-1">Marca / Fabricante</label>
                    <div class="grid grid-cols-2 gap-2">
                        {['FAPLAC', 'EGGER', 'SADEPAN', 'OTRO'].map(brand => (
                            <button class="brand-btn bg-white/5 hover:bg-white/10 border border-white/10 rounded-2xl py-4 text-white font-bold transition-all" data-brand={brand}>{brand}</button>
                        ))}
                    </div>
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-white/40 uppercase mb-2 ml-1">Espesor Placa (mm)</label>
                    <select id="setup-thickness" class="w-full bg-white/5 border border-white/10 rounded-2xl px-4 py-3 text-white font-bold outline-none focus:border-primary transition-all">
                        <option value="18">18 mm</option>
                        <option value="15">15 mm</option>
                        <option value="25">25 mm</option>
                        <option value="5.5">5.5 mm</option>
                    </select>
                </div>
            </div>

            <div id="custom-size-panel" class="space-y-4 opacity-100 transition-opacity">
                <div>
                    <label class="block text-[10px] font-bold text-white/40 uppercase mb-2 ml-1">Largo de Placa (mm)</label>
                    <input type="number" id="setup-width" value="2750" class="w-full bg-white/5 border border-white/10 rounded-2xl px-4 py-3 text-white font-bold outline-none focus:border-primary transition-all" />
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-white/40 uppercase mb-2 ml-1">Ancho de Placa (mm)</label>
                    <input type="number" id="setup-height" value="1830" class="w-full bg-white/5 border border-white/10 rounded-2xl px-4 py-3 text-white font-bold outline-none focus:border-primary transition-all" />
                </div>
                <div class="bg-primary/20 border border-primary/30 rounded-2xl p-4">
                    <p class="text-[10px] text-primary font-black uppercase mb-1">Cálculo de Refilado</p>
                    <p class="text-xs text-white/80">Se descontarán <span class="font-bold underline">5mm</span> automáticamente de cada lado para asegurar cortes limpios.</p>
                </div>
            </div>
        </div>

        <button id="start-loading-btn" class="w-full mt-8 py-5 bg-primary hover:bg-primary-dark text-black font-black rounded-2xl shadow-[0_0_30px_rgba(255,40,0,0.3)] transform transition-active active:scale-95 uppercase tracking-widest">
            Comenzar Carga de Cortes
        </button>
    </div>

    <!-- STEP 2: PIECE ENTRY (HIDDEN INITIALLY) -->
    <div id="step-entry" class="hidden space-y-6">
        
        <!-- Header / Stats Overlay -->
        <div class="flex justify-between items-center bg-white/5 backdrop-blur-md p-4 rounded-2xl border border-white/10 sticky top-4 z-10 shadow-xl">
            <button id="back-to-setup" class="text-white/60 hover:text-white flex items-center gap-2 text-xs font-bold uppercase transition-all">
                <i class="fas fa-cog"></i> Config
            </button>
            <div class="flex gap-4">
                <div class="text-right">
                    <p class="text-[9px] text-white/40 uppercase font-bold">Piezas</p>
                    <p id="stat-pieces" class="text-xl font-black text-primary">0</p>
                </div>
                <div class="text-right">
                    <p class="text-[9px] text-white/40 uppercase font-bold">Total m²</p>
                    <p id="stat-m2" class="text-xl font-black text-white">0.00</p>
                </div>
            </div>
        </div>

        <!-- The "One-at-a-time" Entry Form -->
        <div class="bg-primary border-4 border-black rounded-3xl p-6 shadow-2xl relative overflow-hidden group">
            <div class="absolute top-0 right-0 p-4 opacity-20 pointer-events-none transform group-focus-within:rotate-12 transition-transform">
                <i class="fas fa-cut text-6xl"></i>
            </div>
            
            <h3 class="text-black font-black uppercase text-xl mb-4 tracking-tighter">Nueva Pieza</h3>
            
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                <div class="col-span-2 md:col-span-1">
                    <label class="block text-[10px] font-black text-black/60 uppercase mb-1">Cantidad</label>
                    <input type="number" id="p-qty" placeholder="1" class="w-full bg-white border-2 border-black rounded-xl px-4 py-3 text-xl font-black text-black outline-none" />
                </div>
                <div>
                    <label class="block text-[10px] font-black text-black/60 uppercase mb-1">Largo (mm)</label>
                    <input type="number" id="p-len" placeholder="0" class="w-full bg-white border-2 border-black rounded-xl px-4 py-3 text-xl font-black text-black outline-none" />
                </div>
                <div>
                    <label class="block text-[10px] font-black text-black/60 uppercase mb-1">Ancho (mm)</label>
                    <input type="number" id="p-wid" placeholder="0" class="w-full bg-white border-2 border-black rounded-xl px-4 py-3 text-xl font-black text-black outline-none" />
                </div>
                <div class="col-span-2 md:col-span-1">
                    <label class="block text-[10px] font-black text-black/60 uppercase mb-1">Sentido de Veta</label>
                    <label class="flex items-center gap-2 bg-white border-2 border-black rounded-xl py-3 px-4 cursor-pointer hover:bg-white/80 transition-all h-[54px]">
                        <input type="checkbox" id="p-check-rot" checked class="w-5 h-5 accent-black" />
                        <span class="text-[10px] font-black text-black uppercase">Permitir Gire</span>
                    </label>
                </div>
            </div>

            <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-[10px] font-black text-black/60 uppercase mb-1">Nombre / Identificador</label>
                    <input type="text" id="p-label" placeholder="Ej: Puerta Bajo Mesada" class="w-full bg-white border-2 border-black rounded-xl px-4 py-3 text-lg font-bold text-black outline-none" />
                </div>
                <div>
                    <label class="block text-[10px] font-black text-black/60 uppercase mb-1">Tapacantos (S-I-Iz-D) <span class="text-[8px] opacity-70">- Espesor en mm</span></label>
                    <div class="flex gap-1">
                        <select id="pe-t" class="flex-1 bg-white border-2 border-black rounded-lg py-3 text-[11px] font-black text-black appearance-none text-center focus:ring-2 focus:ring-black transition-all">
                            <option value="0" class="font-bold">SIN</option>
                            <option value="0.45" class="font-bold">0.45 mm</option>
                            <option value="1" class="font-bold">1.00 mm</option>
                            <option value="2" class="font-bold">2.00 mm</option>
                        </select>
                        <select id="pe-b" class="flex-1 bg-white border-2 border-black rounded-lg py-3 text-[11px] font-black text-black appearance-none text-center focus:ring-2 focus:ring-black transition-all">
                            <option value="0" class="font-bold">SIN</option>
                            <option value="0.45" class="font-bold">0.45 mm</option>
                            <option value="1" class="font-bold">1.00 mm</option>
                            <option value="2" class="font-bold">2.00 mm</option>
                        </select>
                        <select id="pe-l" class="flex-1 bg-white border-2 border-black rounded-lg py-3 text-[11px] font-black text-black appearance-none text-center focus:ring-2 focus:ring-black transition-all">
                            <option value="0" class="font-bold">SIN</option>
                            <option value="0.45" class="font-bold">0.45 mm</option>
                            <option value="1" class="font-bold">1.00 mm</option>
                            <option value="2" class="font-bold">2.00 mm</option>
                        </select>
                        <select id="pe-r" class="flex-1 bg-white border-2 border-black rounded-lg py-3 text-[11px] font-black text-black appearance-none text-center focus:ring-2 focus:ring-black transition-all">
                            <option value="0" class="font-bold">SIN</option>
                            <option value="0.45" class="font-bold">0.45 mm</option>
                            <option value="1" class="font-bold">1.00 mm</option>
                            <option value="2" class="font-bold">2.00 mm</option>
                        </select>
                    </div>
                </div>
            </div>

            <button id="p-add-btn" class="w-full mt-6 py-4 bg-black text-white font-black rounded-2xl hover:bg-gray-900 transition-all uppercase tracking-widest shadow-xl flex items-center justify-center gap-2">
                <i class="fas fa-plus"></i> AGREGAR (ENTER)
            </button>
        </div>

        <!-- List of Pieces (Card Based for Mobile) -->
        <div class="space-y-3" id="pieces-container">
            <!-- Piece cards will be injected here -->
        </div>

        <!-- NEW: Material Summary / Finalize Action -->
        <div id="material-actions" class="mt-8 p-6 bg-white/5 border border-white/10 rounded-3xl text-center space-y-4">
            <div class="flex flex-col md:flex-row justify-center items-center gap-4">
                <button id="btn-finalize-sheet" class="w-full md:w-auto px-8 py-4 bg-white/10 hover:bg-white/20 text-white font-bold rounded-2xl border border-white/20 transition-all flex items-center justify-center gap-2">
                    <i class="fas fa-layer-group"></i> FINALIZAR ESTA PLACA Y AGREGAR OTRO MATERIAL
                </button>
            </div>
            <p class="text-[10px] text-white/30 uppercase tracking-widest font-bold">O termina tu pedido si ya cargaste todo</p>
        </div>

        <!-- History of Loaded Materials -->
        <div id="materials-history" class="hidden mt-12 space-y-4">
            <h3 class="text-xl font-black text-white uppercase tracking-tighter flex items-center gap-3">
                <i class="fas fa-history text-primary"></i> Materiales Cargados
            </h3>
            <div id="history-container" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <!-- Finalized material summaries here -->
            </div>
        </div>

        <!-- Final Actions -->
        <div class="flex flex-col md:flex-row gap-4 pt-12">
            <button id="final-lepton" class="flex-1 py-5 bg-white/5 border-2 border-white/10 hover:border-primary text-white font-black rounded-3xl uppercase tracking-widest transition-all group">
                <i class="fas fa-copy group-hover:scale-110 transition-transform"></i> Copiar para Lepton (Vendedor)
            </button>
            <button id="final-visual" class="flex-1 py-5 bg-white/5 border-2 border-white/10 hover:border-green-500 text-white font-black rounded-3xl uppercase tracking-widest transition-all">
                <i class="fab fa-whatsapp"></i> Generar Resumen WhatsApp
            </button>
        </div>
    </div>
</div>

<script>
    import { currentSheetItems, addPiece, removePiece, sheetConfig, updateSheetConfig, finalizeSheet, allSheets, getLeptonExport, getVisualSummary } from '../budgetStore';

    const setupPanel = document.getElementById('step-setup');
    const entryPanel = document.getElementById('step-entry');
    const brandBtns = document.querySelectorAll('.brand-btn');
    const startBtn = document.getElementById('start-loading-btn');
    const backBtn = document.getElementById('back-to-setup');
    const finalizeBtn = document.getElementById('btn-finalize-sheet');
    const historyContainer = document.getElementById('history-container');
    const materialsHistory = document.getElementById('materials-history');
    
    // Setup inputs
    const setThick = document.getElementById('setup-thickness');
    const setWidth = document.getElementById('setup-width');
    const setHeight = document.getElementById('setup-height');
    
    // Entry inputs
    const pQty = document.getElementById('p-qty');
    const pLen = document.getElementById('p-len');
    const pWid = document.getElementById('p-wid');
    const pCheckRot = document.getElementById('p-check-rot');
    const pLab = document.getElementById('p-label');
    const peT = document.getElementById('pe-t');
    const peB = document.getElementById('pe-b');
    const peL = document.getElementById('pe-l');
    const peR = document.getElementById('pe-r');
    const pAdd = document.getElementById('p-add-btn');

    // BRAND SELECTION
    brandBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            brandBtns.forEach(b => b.classList.remove('bg-primary', 'text-black', 'border-black'));
            btn.classList.add('bg-primary', 'text-black', 'border-black');
            const brand = btn.dataset.brand;
            updateSheetConfig({ brand });
            
            const conf = sheetConfig.get();
            if (setWidth && setHeight) {
                setWidth.value = conf.width;
                setHeight.value = conf.height;
            }
            document.getElementById('custom-size-panel').style.opacity = brand === 'OTRO' ? '1' : '0.5';
        });
    });

    // STEP TRANSITIONS
    startBtn.addEventListener('click', () => {
        updateSheetConfig({ 
            thickness: parseFloat(setThick.value), 
            width: parseInt(setWidth.value), 
            height: parseInt(setHeight.value),
            isSetup: true 
        });
        setupPanel.classList.add('hidden');
        entryPanel.classList.remove('hidden');
        pQty.focus();
    });

    backBtn.addEventListener('click', () => {
        setupPanel.classList.remove('hidden');
        entryPanel.classList.add('hidden');
    });

    // FINALIZE SHEET & ADD ANOTHER
    finalizeBtn.addEventListener('click', () => {
        if (finalizeSheet()) {
            setupPanel.classList.remove('hidden');
            entryPanel.classList.add('hidden');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        } else {
            alert('Cargue al menos una pieza antes de finalizar el material.');
        }
    });

    // SMART ENTER LOGIC
    const flow = [pQty, pLen, pWid, pLab];
    flow.forEach((el, idx) => {
        el.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                e.preventDefault();
                if (idx < flow.length - 1) {
                    flow[idx+1].focus();
                } else {
                    savePiece();
                }
            }
        });
    });

    pAdd.addEventListener('click', savePiece);

    function savePiece() {
        const q = parseInt(pQty.value) || 1;
        const l = parseInt(pLen.value);
        const w = parseInt(pWid.value);
        
        if (!l || !w) {
            alert('Ingrese Largo y Ancho en mm');
            return;
        }

        addPiece({
            quantity: q,
            length: l,
            width: w,
            label: pLab.value,
            canRotate: pCheckRot.checked,
            edges: {
                top: parseFloat(peT.value),
                bottom: parseFloat(peB.value),
                left: parseFloat(peL.value),
                right: parseFloat(peR.value),
            }
        });

        // Reset & Return Focus
        pQty.value = '';
        pLen.value = '';
        pWid.value = '';
        pLab.value = '';
        peT.value = '0'; peB.value = '0'; peL.value = '0'; peR.value = '0';
        pQty.focus();
    }

    // LIST RENDERING
    const container = document.getElementById('pieces-container');
    const statPieces = document.getElementById('stat-pieces');
    const statM2 = document.getElementById('stat-m2');

    currentSheetItems.subscribe(items => {
        statPieces.textContent = items.reduce((acc, i) => acc + i.quantity, 0);
        const m2 = items.reduce((acc, i) => acc + (i.length * i.width * i.quantity) / 1000000, 0);
        statM2.textContent = m2.toFixed(2);

        container.innerHTML = items.slice().reverse().map(item => `
            <div class="bg-white/5 border border-white/10 rounded-2xl p-4 flex justify-between items-center group hover:bg-white/10 transition-all animate-in slide-in-from-right duration-300">
                <div class="flex gap-4 items-center">
                    <div class="bg-primary text-black font-black w-10 h-10 rounded-full flex items-center justify-center text-lg">${item.quantity}</div>
                    <div>
                        <p class="text-white font-black text-lg">${item.length} <span class="text-white/30">x</span> ${item.width} <span class="text-[10px] text-white/40 uppercase ml-2">mm</span></p>
                        <p class="text-white/40 text-xs font-bold uppercase italic">${item.label || 'Pieza sin nombre'}</p>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <div class="flex gap-0.5">
                        ${renderEdgeDot(item.edges.top)}
                        ${renderEdgeDot(item.edges.bottom)}
                        ${renderEdgeDot(item.edges.left)}
                        ${renderEdgeDot(item.edges.right)}
                    </div>
                    <button onclick="window.removeSmartPiece('${item.id}')" class="text-white/20 hover:text-red-500 transition-all text-xl p-2">
                        <i class="fas fa-trash-alt"></i>
                    </button>
                </div>
            </div>
        `).join('');
    });

    // ALL SHEETS HISTORY RENDERING
    allSheets.subscribe(sheets => {
        if (sheets.length > 0) {
            materialsHistory.classList.remove('hidden');
            historyContainer.innerHTML = sheets.map((s, idx) => `
                <div class="bg-[#1a1a1a] border border-primary/20 rounded-2xl p-5 relative overflow-hidden group">
                    <div class="absolute -right-4 -top-4 w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center font-black text-primary/40 text-2xl pt-2 pr-2">#${idx + 1}</div>
                    <h4 class="text-white font-bold text-lg mb-1">${s.config.brand} <span class="text-primary">${s.config.thickness}mm</span></h4>
                    <p class="text-[10px] text-white/40 uppercase font-black mb-3 italic">${s.items.length} piezas cargadas • ${(s.items.reduce((a,i)=>a+(i.length*i.width*i.quantity)/1000000,0)).toFixed(2)}m²</p>
                    <div class="flex gap-2">
                        <div class="px-3 py-1 bg-white/5 rounded-lg text-[10px] text-white/60 font-bold uppercase">${s.config.width}x${s.config.height}mm</div>
                    </div>
                </div>
            `).join('');
        } else {
            materialsHistory.classList.add('hidden');
        }
    });

    function renderEdgeDot(val) {
        if (val === 0) return `<div class="w-1.5 h-1.5 rounded-full border border-white/10"></div>`;
        if (val === 0.45) return `<div class="w-1.5 h-1.5 rounded-full bg-blue-500 shadow-[0_0_5px_rgba(59,130,246,0.5)]" title="0.45mm"></div>`;
        if (val === 1) return `<div class="w-1.5 h-1.5 rounded-full bg-yellow-500 shadow-[0_0_5px_rgba(234,179,8,0.5)]" title="1.00mm"></div>`;
        if (val === 2) return `<div class="w-1.5 h-1.5 rounded-full bg-red-500 shadow-[0_0_5px_rgba(239,68,68,0.5)]" title="2.00mm"></div>`;
        return '';
    }

    window.removeSmartPiece = (id) => removePiece(id);

    // EXPORT ACTIONS
    document.getElementById('final-lepton').addEventListener('click', () => {
        const text = getLeptonExport();
        if (!text) return alert('Agregue piezas primero');
        navigator.clipboard.writeText(text).then(() => {
            const btn = document.getElementById('final-lepton');
            const original = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-check text-green-500"></i> ¡LISTO PARA PEGAR!';
            btn.classList.add('border-green-500', 'text-green-500');
            setTimeout(() => {
                btn.innerHTML = original;
                btn.classList.remove('border-green-500', 'text-green-500');
            }, 3000);
        });
    });

    document.getElementById('final-visual').addEventListener('click', () => {
        const summary = getVisualSummary();
        if (!summary.includes('PLACA #1')) return alert('Agregue piezas primero');
        
        // WhatsApp Export (Basic URL encoding)
        const encoded = encodeURIComponent(summary);
        window.open(`https://wa.me/?text=${encoded}`, '_blank');
    });

</script>

<style>
    /* Premium aesthetics */
    #smart-flow-engine { perspective: 1000px; }
    .brand-btn.bg-primary { box-shadow: 0 0 20px rgba(255, 40, 0, 0.4); transform: translateY(-2px); }
    input::-webkit-outer-spin-button, input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
    input[type=number] { -moz-appearance: textfield; }
    .brand-btn:active { transform: scale(0.95); }
    .animate-in { animation-fill-mode: both; }
    @keyframes slideIn { from { opacity: 0; transform: translateX(20px); } to { opacity: 1; transform: translateX(0); } }
    .slide-in-right { animation: slideIn 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
</style>
