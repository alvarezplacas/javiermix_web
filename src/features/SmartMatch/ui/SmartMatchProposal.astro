---
const { matchResult } = Astro.props;
---

<div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
    <!-- Columna Izquierda: La Elección (60%) -->
    <div class="lg:col-span-4 space-y-6">
        <div class="relative group">
            <div class="absolute -inset-1 bg-gradient-to-r from-primary to-orange-600 rounded-2xl blur opacity-25 group-hover:opacity-50 transition duration-1000"></div>
            <div class="relative bg-[#1a1a1a] rounded-2xl overflow-hidden border border-gray-800">
                <div class="aspect-square w-full">
                    <img src={matchResult.base.imagen} alt={matchResult.base.nombre} class="w-full h-full object-cover" />
                </div>
                <div class="p-6">
                    <span class="bg-primary/20 text-primary text-[10px] font-bold px-2 py-1 rounded uppercase tracking-widest mb-3 inline-block">60% BASE</span>
                    <h3 class="text-2xl font-bold mb-1">{matchResult.base.nombre}</h3>
                    <p class="text-gray-500 text-sm uppercase tracking-widest">{matchResult.base.marca} | {matchResult.base.linea}</p>
                </div>
            </div>
        </div>

        <div class="bg-[#111] p-6 rounded-2xl border border-gray-800/50 italic text-gray-400 leading-relaxed relative overflow-hidden">
            <div class="absolute top-0 left-0 w-1 h-full bg-primary/40"></div>
            “{matchResult.explicacion}”
        </div>
    </div>

    <!-- Columna Derecha: Sugerencias (30-10) -->
    <div class="lg:col-span-8 space-y-8">
        <div class="flex items-center justify-between mb-2">
            <h2 class="text-2xl font-bold flex items-center gap-3">
                <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                Propuesta de Combinación
            </h2>
            <button onclick="window.print()" class="bg-white/5 hover:bg-white/10 text-white text-xs font-bold py-2 px-4 rounded-full border border-white/10 transition-all flex items-center gap-2">
                Imprimir Propuesta
            </button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-print">
            <!-- 30% Secundario -->
            <div class="bg-[#1a1a1a] rounded-2xl overflow-hidden border border-gray-800 flex flex-col h-full">
                <div class="h-48 md:h-64 overflow-hidden relative">
                    <div class="absolute top-4 left-4 z-10 bg-slate-100 text-slate-800 text-[10px] font-bold px-2 py-1 rounded-sm tracking-widest shadow-lg">30% CONTRASTE</div>
                    <img src={matchResult.secundario.imagen} alt={matchResult.secundario.nombre} class="w-full h-full object-cover transition-transform duration-700 hover:scale-110" />
                </div>
                <div class="p-6">
                    <h4 class="text-xl font-bold mb-1">{matchResult.secundario.nombre}</h4>
                    <p class="text-gray-500 text-xs uppercase tracking-widest">{matchResult.secundario.marca} | {matchResult.secundario.linea}</p>
                    <p class="text-gray-400 text-sm mt-4 leading-relaxed">
                        Elegido para aportar equilibrio visual y reducir la saturación del color principal.
                    </p>
                </div>
            </div>

            <!-- 10% Acento -->
            <div class="bg-[#1a1a1a] rounded-2xl overflow-hidden border border-gray-800 flex flex-col h-full">
                <div class="h-48 md:h-64 overflow-hidden relative">
                    <div class="absolute top-4 left-4 z-10 bg-orange-500 text-white text-[10px] font-bold px-2 py-1 rounded-sm tracking-widest shadow-lg">10% ACENTO</div>
                    <img src={matchResult.acento.imagen} alt={matchResult.acento.nombre} class="w-full h-full object-cover transition-transform duration-700 hover:scale-110" />
                </div>
                <div class="p-6">
                    <h4 class="text-xl font-bold mb-1">{matchResult.acento.nombre}</h4>
                    <p class="text-gray-500 text-xs uppercase tracking-widest">{matchResult.acento.marca} | {matchResult.acento.linea}</p>
                    <p class="text-gray-400 text-sm mt-4 leading-relaxed">
                        El toque maestro. Destinado a puntos focales como detalles de diseño o accesorios.
                    </p>
                </div>
            </div>
        </div>

        <!-- Botones de Acción -->
        <div class="flex flex-col sm:flex-row gap-4 mt-8 no-print">
            <a 
                href={`https://wa.me/5491100000000?text=Hola! Estuve usando el Smart Match de Alvarez Placas y me encantó esta combinación: Base ${matchResult.base.nombre}, Secundario ${matchResult.secundario.nombre} y Acento ${matchResult.acento.nombre}. ¿Me pasarías presupuesto?`}
                target="_blank"
                class="flex-1 bg-[#25D366] hover:bg-[#1ebd5a] text-white font-bold py-4 px-6 rounded-xl flex items-center justify-center gap-3 transition-all shadow-lg shadow-[#25D366]/20"
            >
                Enviar Combinación
            </a>
            <a href="/catalogo" class="flex-1 bg-white/5 hover:bg-white/10 text-white font-bold py-4 px-6 rounded-xl flex items-center justify-center gap-3 border border-white/10 transition-all">
                Elegir otra placa
            </a>
        </div>
    </div>
</div>
