---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">

  <!-- Mapa del Sitio Principal -->
  <div class="footer-sitemap">
    <div class="sitemap-inner">

      <!-- Columna: Marca -->
      <div class="footer-brand">
        <p class="brand-signature">Javier Mix</p>
        <p class="brand-tagline">Fotografía Fine Art · Buenos Aires</p>
        <p class="brand-desc">
          Colecciones exclusivas donde la luz, el metal y la memoria convergen en obra de autor. Para coleccionistas y decoradores de interiores que buscan una presencia sólida y honesta.
        </p>
        <div class="footer-socials">
          <a href="#" aria-label="Instagram" class="social-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            Instagram
          </a>
          <a href="#" aria-label="WhatsApp" class="social-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            WhatsApp
          </a>
          <a href="#" aria-label="Behance" class="social-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12C1 5.9 5.9 1 12 1s11 5 11 11-5 11-11 11S1 18.1 1 12z"/><path d="M10 8H6v8h4.5a2.5 2.5 0 0 0 0-5H6"/><line x1="14" y1="9" x2="18" y2="9"/><path d="M18 13h-4c0 1.1.9 2 2 2s2-.5 2-2z"/></svg>
            Behance
          </a>
        </div>
      </div>

      <!-- Columna: Colecciones -->
      <nav class="footer-nav-col" aria-label="Colecciones de obras">
        <h4 class="footer-nav-title">
          <span class="nav-title-line"></span>
          Colecciones
        </h4>
        <ul>
          <li><a href="/galeria">Ver Portfolio Completo</a></li>
          <li><a href="/galeria/Rostros_de_metal">Rostros de Metal</a></li>
          <li><a href="/galeria/Epidermis_urbana">Epidermis Urbana</a></li>
          <li><a href="/galeria/Estructuras">Estructuras</a></li>
          <li><a href="/galeria/Monumentos">Monumentos</a></li>
          <li><a href="/galeria" class="link-all">→ Ver todas las series</a></li>
        </ul>
      </nav>

      <!-- Columna: Servicios -->
      <nav class="footer-nav-col" aria-label="Servicios">
        <h4 class="footer-nav-title">
          <span class="nav-title-line"></span>
          Servicios
        </h4>
        <ul>
          <li><a href="/enmarcado">Studio de Enmarcado</a></li>
          <li><a href="/enmarcado">Prueba tu Obra en tu Espacio</a></li>
          <li><a href="#">Impresión Fine Art</a></li>
          <li><a href="#">Consultoría de Arte</a></li>
          <li><a href="#">Ediciones Limitadas</a></li>
        </ul>
      </nav>

      <!-- Columna: Revista -->
      <nav class="footer-nav-col" aria-label="Revista">
        <h4 class="footer-nav-title">
          <span class="nav-title-line"></span>
          Revista Digital
        </h4>
        <ul>
          <li><a href="/revista">Últimas Notas</a></li>
          <li><a href="/revista/cartografo-de-lo-invisible">Cartógrafo de lo Invisible</a></li>
          <li><a href="/revista/la-luz-en-el-interior">La Luz en el Interior</a></li>
          <li><a href="/revista/el-metal-como-memoria">El Metal Como Memoria</a></li>
          <li><a href="/revista" class="link-all">→ Ver todas las notas</a></li>
        </ul>
      </nav>

      <!-- Columna: Contacto -->
      <nav class="footer-nav-col" aria-label="Contacto">
        <h4 class="footer-nav-title">
          <span class="nav-title-line"></span>
          Contacto
        </h4>
        <ul>
          <li class="contact-item">
            <span class="contact-label">Consultas de Obra</span>
            <a href="mailto:info@javiermix.com">info@javiermix.com</a>
          </li>
          <li class="contact-item">
            <span class="contact-label">WhatsApp</span>
            <a href="#">+54 9 11 XXXX XXXX</a>
          </li>
          <li class="contact-item">
            <span class="contact-label">Estudio</span>
            <span>Buenos Aires, Argentina</span>
          </li>
        </ul>
      </nav>

    </div>
  </div>

  <!-- Separador decorativo -->
  <div class="footer-divider">
    <span class="divider-line"></span>
    <span class="divider-mark">JM</span>
    <span class="divider-line"></span>
  </div>

  <!-- Footer Bottom -->
  <div class="footer-bottom">
    <div class="footer-bottom-inner">
      <p class="copyright">&copy; {currentYear} Javier Mix. Todos los derechos reservados.</p>
      <div class="bottom-links">
        <a href="#">Política de Privacidad</a>
        <a href="#">Términos de Uso</a>
        <a href="#">Envíos y Devoluciones</a>
        <a href="/admin" class="admin-access-link"><i class="fas fa-lock"></i> Admin</a>
      </div>
    </div>
  </div>

</footer>

<style>
  .site-footer {
    background-color: #080808;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
    font-family: var(--font-secondary);
    color: var(--color-text-muted);
  }

  /* Sitemap */
  .footer-sitemap {
    padding: 8rem 5% 6rem;
    max-width: 1600px;
    margin: 0 auto;
  }

  .sitemap-inner {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    gap: 5rem;
  }

  /* Brand Column */
  .brand-signature {
    font-family: var(--font-primary);
    font-size: 2.5rem;
    font-weight: 400;
    font-style: italic;
    color: var(--color-white);
    margin-bottom: 0.5rem;
    letter-spacing: 2px;
  }

  .brand-tagline {
    font-size: 0.7rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 2rem;
  }

  .brand-desc {
    font-size: 0.85rem;
    line-height: 1.9;
    color: var(--color-text-muted);
    margin-bottom: 2.5rem;
    max-width: 300px;
  }

  .footer-socials {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.8rem;
    letter-spacing: 1px;
    transition: var(--transition-premium);
  }

  .social-link:hover {
    color: var(--color-accent);
    transform: translateX(5px);
  }

  /* Nav Columns */
  .footer-nav-col {
    padding-top: 0.5rem;
  }

  .footer-nav-title {
    font-family: var(--font-primary);
    font-size: 1.3rem;
    color: var(--color-white);
    font-weight: 400;
    margin-bottom: 2.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .nav-title-line {
    display: block;
    width: 24px;
    height: 1px;
    background-color: var(--color-accent);
    flex-shrink: 0;
  }

  .footer-nav-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .footer-nav-col a {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.8rem;
    transition: var(--transition-premium);
    display: block;
  }

  .footer-nav-col a:hover {
    color: var(--color-white);
    padding-left: 6px;
  }

  .link-all {
    color: var(--color-accent) !important;
    margin-top: 0.5rem;
    font-weight: 600;
  }

  .link-all:hover {
    padding-left: 10px !important;
  }

  /* Contact Items */
  .contact-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .contact-label {
    font-size: 0.65rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-travertine-dark);
  }

  .contact-item a,
  .contact-item span {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.3s;
  }

  .contact-item a:hover {
    color: var(--color-accent);
  }

  /* Divider */
  .footer-divider {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 0 5%;
    max-width: 1600px;
    margin: 0 auto 4rem;
  }

  .divider-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(255,255,255,0.06));
  }

  .footer-divider .divider-line:last-child {
    background: linear-gradient(to left, transparent, rgba(255,255,255,0.06));
  }

  .divider-mark {
    font-family: var(--font-primary);
    font-size: 1.2rem;
    font-style: italic;
    color: rgba(255,255,255,0.15);
    letter-spacing: 4px;
    flex-shrink: 0;
  }

  /* Bottom bar */
  .footer-bottom {
    padding: 2rem 5%;
    border-top: 1px solid rgba(255,255,255,0.04);
    max-width: 1600px;
    margin: 0 auto;
  }

  .footer-bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .copyright {
    font-size: 0.75rem;
    color: var(--color-travertine-dark);
    letter-spacing: 1px;
  }

  .bottom-links {
    display: flex;
    gap: 2rem;
  }

  .bottom-links a {
    font-size: 0.72rem;
    color: var(--color-travertine-dark);
    text-decoration: none;
    letter-spacing: 1px;
    transition: color 0.3s;
  }

  .bottom-links a:hover {
    color: var(--color-text-muted);
  }

  /* Responsive */
  @media (max-width: 1200px) {
    .sitemap-inner {
      grid-template-columns: 1fr 1fr 1fr;
      gap: 3rem;
    }
    .footer-brand {
      grid-column: span 3;
    }
  }

  @media (max-width: 768px) {
    .sitemap-inner {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }
    .footer-brand {
      grid-column: span 2;
    }
    .footer-bottom-inner {
      flex-direction: column;
      text-align: center;
    }
    .bottom-links {
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem;
    }
  }

  @media (max-width: 480px) {
    .sitemap-inner {
      grid-template-columns: 1fr;
    }
    .footer-brand {
      grid-column: span 1;
    }
  }
</style>
