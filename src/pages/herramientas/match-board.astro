---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
---

<Layout title="Match-Board | Alvarez Placas">
    <Header />
    <main class="pt-24 min-h-screen bg-[#111111] px-4 sm:px-6">
        <div class="max-w-4xl mx-auto text-center">
            <div class="w-20 h-20 bg-purple-500/10 text-purple-400 rounded-3xl flex items-center justify-center mx-auto mb-6 border border-purple-500/20 shadow-xl shadow-purple-500/5">
                <i class="fas fa-layer-group text-3xl"></i>
            </div>
            <h1 class="text-4xl font-extrabold text-white tracking-tight uppercase mb-4">Alvarez <span class="text-purple-400 italic">Match-Board</span></h1>
            <p class="text-gray-400 text-lg mb-10 max-w-2xl mx-auto">Creá combinaciones de colores sorprendentes para tus proyectos de carpintería.</p>
            
            <div class="bg-[#1a1a1a] border border-gray-800 rounded-2xl p-8 mb-8">
                <div class="flex flex-col items-center gap-4 text-purple-400 mb-6 font-bold uppercase tracking-widest text-xs">
                    <i class="fas fa-sync fa-spin text-2xl"></i>
                    <span>Próximamente disponible</span>
                </div>
                <p class="text-sm text-gray-500 mb-8">Estamos preparando una experiencia premium para que puedas exportar tus moodboards en PDF con un diseño profesional.</p>
                <a href="/smart-match" class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white font-bold rounded-xl hover:bg-primary-light transition-all shadow-lg shadow-primary/20">
                    <i class="fas fa-magic"></i>
                    Usar Smart Match (Disponible)
                </a>
            </div>
        </div>
    </main>
</Layout>
