---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Estamos Mejorando - Alvarez Placas">
    <div class="min-h-screen flex items-center justify-center p-6 bg-[#0a0a0a] relative overflow-hidden">
        <!-- Abstract Animated Background -->
        <div class="absolute top-0 left-0 w-full h-full opacity-30">
            <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-primary/30 rounded-full blur-[120px] animate-pulse"></div>
            <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-blue-600/20 rounded-full blur-[120px] animate-pulse transition-all duration-1000"></div>
        </div>

        <div class="max-w-xl w-full bg-white/[0.03] backdrop-blur-xl border border-white/10 rounded-[3rem] p-10 md:p-16 text-center shadow-[0_30px_100px_rgba(0,0,0,0.5)] relative z-10">
            <div class="mb-10 relative">
                <div class="w-32 h-32 bg-primary rounded-[2.5rem] rotate-12 mx-auto flex items-center justify-center shadow-2xl shadow-primary/40 group hover:rotate-0 transition-transform duration-500">
                    <i class="fas fa-tools text-5xl text-black group-hover:scale-110 transition-transform"></i>
                </div>
                <!-- Mini Floating Icons -->
                <i class="fas fa-hammer absolute -top-4 right-1/4 text-primary/40 text-xl animate-bounce"></i>
                <i class="fas fa-ruler absolute bottom-0 left-1/4 text-primary/40 text-xl animate-pulse"></i>
            </div>
            
            <h1 class="text-4xl md:text-5xl font-black text-white mb-6 tracking-tighter uppercase leading-none">
                Estamos <br/><span class="text-primary italic">Actualizando</span>
            </h1>
            
            <div class="space-y-4 mb-12">
                <p class="text-lg md:text-xl text-white/70 font-medium leading-relaxed">
                    Estamos trabajando para brindarte una mejor experiencia en nuestro sitio web.
                </p>
                <p class="text-primary font-black text-xs uppercase tracking-[0.3em]">
                    Gracias por tu paciencia
                </p>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div class="bg-white/5 border border-white/10 rounded-2xl p-4 transition-colors hover:bg-white/10">
                    <div class="flex items-center justify-center gap-2 mb-1">
                        <span class="w-2 h-2 bg-green-500 rounded-full shadow-[0_0_8px_#22c55e]"></span>
                        <span class="text-[10px] font-black text-white/40 uppercase tracking-widest">Sistema</span>
                    </div>
                    <p class="text-xs font-bold text-white">Online</p>
                </div>
                <div class="bg-white/5 border border-white/10 rounded-2xl p-4 transition-colors hover:bg-white/10">
                    <div class="flex items-center justify-center gap-2 mb-1">
                        <i class="fas fa-code-branch text-[10px] text-primary"></i>
                        <span class="text-[10px] font-black text-white/40 uppercase tracking-widest">Versión</span>
                    </div>
                    <p class="text-xs font-bold text-white">2.0.4 Premium</p>
                </div>
            </div>
        </div>

        <!-- Decorative Bottom Bar -->
        <div class="fixed bottom-0 left-0 w-full h-[2px] bg-white/5 overflow-hidden">
            <div class="h-full bg-gradient-to-r from-transparent via-primary to-transparent w-1/4 absolute animate-scan"></div>
        </div>
    </div>
</Layout>

<style>
    @keyframes scan {
        0% { left: -25%; }
        100% { left: 125%; }
    }
    .animate-scan {
        animation: scan 3s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    }
</style>
