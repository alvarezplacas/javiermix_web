---
import '../../styles/global.css';
import BottomNav from '../../components/BottomNav.astro';

const { title = "Mi Cuenta | Alvarez Placas" } = Astro.props;

// Datos del Cliente (Vacíos por defecto hasta login real)
const cliente = {
    nombre: "Usuario",
    puntos: 0,
    pedidosMes: 0,
    diasInactivo: 0,
};

// Pedidos reales (Vacío)
const pedidos = [];
---
<!doctype html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <!-- Google Fonts & FontAwesome -->
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body class="bg-[#111111] text-gray-200 font-sans antialiased pb-20 md:pb-0">

    <!-- Header Móvil -->
    <header class="bg-[#1a1a1a] border-b border-gray-800 sticky top-0 z-50">
        <div class="max-w-5xl mx-auto px-4 h-16 flex items-center justify-between">
            <a href="/" class="text-xl font-bold tracking-tight text-white">
                ALVAREZ<span class="text-primary">PLACAS</span>
            </a>
            <div class="flex items-center gap-3">
                <div class="hidden sm:flex items-center gap-2 px-3 py-1.5 rounded-full bg-primary/10 border border-primary/30 mr-2">
                    <span class="text-primary font-bold">{cliente.puntos}</span>
                    <i class="fas fa-star text-yellow-500 text-xs"></i>
                </div>
                <div class="w-9 h-9 rounded-full bg-gray-700 flex items-center justify-center font-bold text-white">
                    <i class="fas fa-user"></i>
                </div>
            </div>
        </div>
    </header>

    <main class="max-w-5xl mx-auto p-4 sm:p-6 lg:p-8 space-y-6">

        <!-- Welcome Banner (Sin datos mock) -->
        <div class="bg-gradient-to-br from-primary/10 via-[#1a1a1a] to-[#111111] border border-white/10 rounded-2xl p-6 relative overflow-hidden shadow-lg">
            <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-6">
                <div>
                    <h1 class="text-2xl sm:text-3xl font-bold text-white mb-2">Mi Perfil</h1>
                    <p class="text-gray-400">Gestiona tus pedidos y puntos acumulados.</p>
                </div>
                
                <div class="bg-black/40 border border-white/10 rounded-xl p-4 flex items-center gap-4 shrink-0">
                    <div class="w-14 h-14 rounded-full bg-primary/20 text-primary flex items-center justify-center text-2xl">
                        <i class="fas fa-crown"></i>
                    </div>
                    <div>
                        <p class="text-sm text-gray-400 font-semibold uppercase">Puntos Club</p>
                        <p class="text-3xl font-extrabold text-white">{cliente.puntos}</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Botones de Herramientas Rápidas -->
        <h2 class="text-xl font-bold text-white mt-8 mb-4">Mis Herramientas</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            
            <a href="/presupuestador" class="bg-[#1a1a1a] border border-gray-800 hover:border-primary/50 transition-colors rounded-xl p-5 flex flex-col items-center justify-center text-center group cursor-pointer h-full">
                <div class="w-14 h-14 rounded-full bg-primary/10 text-primary flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-all">
                    <i class="fas fa-file-invoice-dollar"></i>
                </div>
                <h3 class="font-bold text-white mb-1">Nuevo Presupuesto</h3>
                <p class="text-xs text-gray-400">Inicia un nuevo pedido de corte ahora.</p>
            </a>

            <a href="/catalogo" class="bg-[#1a1a1a] border border-gray-800 hover:border-blue-500/50 transition-colors rounded-xl p-5 flex flex-col items-center justify-center text-center group cursor-pointer h-full">
                <div class="w-14 h-14 rounded-full bg-blue-500/10 text-blue-500 flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-all">
                    <i class="fas fa-search"></i>
                </div>
                <h3 class="font-bold text-white mb-1">Ver Catálogo</h3>
                <p class="text-xs text-gray-400">Explora materiales y precios actualizados.</p>
            </a>

            <a href="/herramientas" class="bg-[#1a1a1a] border border-gray-800 hover:border-green-500/50 transition-colors rounded-xl p-5 flex flex-col items-center justify-center text-center group cursor-pointer h-full">
                <div class="w-14 h-14 rounded-full bg-green-500/10 text-green-500 flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-all">
                    <i class="fas fa-tools"></i>
                </div>
                <h3 class="font-bold text-white mb-1">Más Herramientas</h3>
                <p class="text-xs text-gray-400">Optimizador, Calculadoras y más.</p>
            </a>
        </div>

        <!-- Tabla de "Mis Pedidos" (Estado Vacío) -->
        <h2 class="text-xl font-bold text-white mt-10 mb-4">Mis Pedidos Recientes</h2>
        
        {pedidos.length > 0 ? (
            <div class="bg-[#1a1a1a] border border-gray-800 rounded-xl overflow-hidden shadow-lg">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <!-- ... (contenido tabla si hubiera pedidos) -->
                    </table>
                </div>
            </div>
        ) : (
            <div class="bg-[#1a1a1a] border border-dashed border-gray-800 rounded-xl p-12 text-center">
                <div class="w-16 h-16 bg-gray-800/50 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i class="fas fa-shopping-bag text-gray-600 text-2xl"></i>
                </div>
                <h3 class="text-lg font-bold text-white mb-1">No hay pedidos registrados</h3>
                <p class="text-gray-500 text-sm max-w-xs mx-auto mb-6">Tus presupuestos y estados de pedidos aparecerán aquí una vez que realices el primero.</p>
                <a href="/presupuestador" class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white font-bold rounded-lg hover:bg-primary-light transition-all">
                    Comenzar Primer Pedido
                </a>
            </div>
        )}

    </main>

    <!-- Navigation Final Reutilizable -->
    <BottomNav />
</body>
</html>
