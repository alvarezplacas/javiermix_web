---
import VendedorLayout from '../../layouts/VendedorLayout.astro';
import StatCard from '../../features/DashboardShared/components/StatCard.astro';
import OrderProcessCard from '../../features/DashboardShared/components/OrderProcessCard.astro';
import { Order } from '../../domain/Order';

const pendingOrders = [
    new Order({ 
        id: '2045', 
        cliente: 'Muebles Express', 
        status: Order.STATUS.PENDIENTE, 
        logistica: Order.LOGISTICS.ENVIO,
        items: [
            {
                name: 'Placa Egger Olmo', 
                price: 45000, 
                quantity: 2,
                medidas: { base: 1200, altura: 600, rota: true, cantos: { arriba: 1, abajo: 1, derecha: 2, izquierda: 2 } }
            }, 
            {
                name: 'Tapacantos 22mm', 
                price: 500, 
                quantity: 10
            }
        ]
    }),
    new Order({ 
        id: '2046', 
        cliente: 'Carpintero José', 
        status: Order.STATUS.PENDIENTE, 
        logistica: Order.LOGISTICS.RETIRO,
        items: [
            {
                name: 'Placa Faplac Seda', 
                price: 38000, 
                quantity: 1,
                medidas: { base: 2600, altura: 1830, rota: false, cantos: { arriba: 0, abajo: 0, derecha: 0, izquierda: 0 } }
            }
        ]
    }),
    new Order({ 
        id: '2047', 
        cliente: 'Decoraciones Lux', 
        status: Order.STATUS.PENDIENTE, 
        logistica: Order.LOGISTICS.ENVIO,
        items: [{name: 'Placa MDF 18', price: 32000, quantity: 5}]
    }),
];
---

<VendedorLayout title="Operaciones Diarias">
    
    <!-- Ultra Focus Header -->
    <div class="mb-10 flex items-center justify-between border-b border-gray-800 pb-6">
        <div>
            <h2 class="text-4xl font-extrabold text-white tracking-tighter uppercase">Panel de <span class="text-primary italic">Acción</span></h2>
            <p class="text-gray-500 font-medium text-sm">Prioriza pedidos pendientes y acelera la producción.</p>
        </div>
        <div class="hidden lg:flex items-center gap-4">
            <div class="text-right">
                <p class="text-[10px] text-gray-500 uppercase font-bold tracking-widest">Estado Sistema</p>
                <p class="text-xs text-green-400 font-bold flex items-center justify-end gap-1"><i class="fas fa-circle text-[8px]"></i> Operativo</p>
            </div>
            <div class="w-12 h-12 rounded-full border border-gray-800 flex items-center justify-center bg-black/40">
                <i class="fas fa-wifi text-xs text-gray-500"></i>
            </div>
        </div>
    </div>

    <!-- Seller Performance Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        <StatCard 
            label="Mis Ventas Hoy" 
            value="$452k" 
            icon="fa-shopping-bag" 
            color="primary" 
            trend={{ value: '15%', isUp: true, label: 'vs meta' }}
        />
        <StatCard 
            label="Pedidos en Corte" 
            value="8" 
            icon="fa-layer-group" 
            color="blue" 
        />
        <StatCard 
            label="Logro del Mes" 
            value="78%" 
            icon="fa-trophy" 
            color="amber" 
            trend={{ value: '92%', isUp: true, label: 'proyectado' }}
        />
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <!-- Main Column: Pending Process (2/3) -->
        <div class="lg:col-span-2 space-y-6">
            <div class="flex items-center justify-between mb-2">
                <h3 class="text-xl font-bold text-white flex items-center gap-2">
                    <i class="fas fa-clock text-amber-500"></i> Pendientes de Procesamiento
                </h3>
                <span class="px-3 py-1 rounded-full bg-amber-500/10 text-amber-500 border border-amber-500/20 text-xs font-bold uppercase tracking-wider">
                    Urgente: {pendingOrders.length}
                </span>
            </div>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {pendingOrders.map(order => (
                    <OrderProcessCard order={order} />
                ))}
            </div>
        </div>

        <!-- Secondary Column: Quick Links & Alerts (1/3) -->
        <div class="space-y-8">
            <div class="bg-gradient-to-br from-[#1a1a1a] to-black border border-gray-800 rounded-2xl p-6 shadow-2xl relative overflow-hidden group">
                <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-primary/10 rounded-full blur-3xl group-hover:bg-primary/20 transition-colors"></div>
                
                <h3 class="text-white font-bold mb-4 flex items-center gap-2 text-sm uppercase tracking-wider">
                    <i class="fas fa-rocket text-primary"></i> Herramientas de Venta
                </h3>
                
                <div class="space-y-3 relative z-10">
                    <a href="/herramientas/optimizador" class="w-full flex items-center gap-4 p-4 rounded-xl bg-gray-900 border border-gray-800 hover:border-primary/50 transition-all text-left">
                        <div class="w-10 h-10 rounded-lg bg-primary/10 text-primary flex items-center justify-center">
                            <i class="fas fa-plus"></i>
                        </div>
                        <div>
                            <p class="text-white font-bold text-sm">Nuevo Optimizado</p>
                            <p class="text-[10px] text-gray-500">Cargar medidas de cliente</p>
                        </div>
                    </a>
                    
                    <a href="/herramientas/calculadora" class="w-full flex items-center gap-4 p-4 rounded-xl bg-gray-900 border border-gray-800 hover:border-blue-500/50 transition-all text-left">
                        <div class="w-10 h-10 rounded-lg bg-blue-500/10 text-blue-500 flex items-center justify-center">
                            <i class="fas fa-calculator"></i>
                        </div>
                        <div>
                            <p class="text-white font-bold text-sm">Cubicador Rápido</p>
                            <p class="text-[10px] text-gray-500">Consultar stock requerido</p>
                        </div>
                    </a>
                </div>
            </div>

            <div class="bg-[#111111] border border-gray-800 rounded-2xl p-6">
                <h3 class="text-white font-bold mb-6 flex items-center gap-2 text-sm uppercase tracking-wider">
                    <i class="fas fa-bell text-gray-500"></i> Alertas de Hoy
                </h3>
                
                <div class="space-y-6">
                    <div class="flex gap-4 group">
                        <div class="w-1.5 h-auto bg-amber-500 rounded-full"></div>
                        <div>
                            <p class="text-white text-xs font-bold">Seguimiento: Presupuesto #890</p>
                            <p class="text-[10px] text-gray-500 mt-1">El cliente "Estudio Sur" aún no aprobó. Vence hoy.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</VendedorLayout>
