---
import Layout from '../../layouts/Layout.astro';

// Mock de presupuestos y pedidos del cliente
const misPresupuestos = [
    { id: "P-1004", fecha: "12/03/2026", material: "MDF 18mm Blanco", total: "$45.200", estado: "Aprobado" },
    { id: "P-1002", fecha: "10/03/2026", material: "MDF 18mm Roble", total: "$68.100", estado: "Entregado" },
];

const pedidoActivo = {
    id: "OCT-2025",
    estado: "En Corte",
    progreso: 65,
    descripcion: "Cortes para cocina - Cliente Los Álamos",
    vendedor: "Martín Giménez"
};
---

<Layout title="Mi Dashboard - Alvarezplacas">
    <div class="max-w-7xl mx-auto px-4 py-8">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
            <div>
                <h1 class="text-3xl font-black text-white">Hola, <span class="text-primary">Carpintería Los Álamos</span></h1>
                <p class="text-gray-400">Bienvenido a tu panel profesional. Aquí puedes gestionar tus pedidos.</p>
            </div>
            <a href="/presupuestador" class="px-6 py-3 bg-primary hover:bg-primary-dark text-black font-black rounded-xl transition-all shadow-[0_0_20px_rgba(255,40,0,0.2)] flex items-center gap-2">
                <i class="fas fa-plus"></i> NUEVO PRESUPUESTO
            </a>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            
            <!-- Tracking Card -->
            <div class="lg:col-span-2 space-y-6">
                <div class="bg-[#1a1a1a] border border-gray-800 rounded-2xl p-6 relative overflow-hidden">
                    <div class="absolute top-0 right-0 p-4 opacity-10">
                        <i class="fas fa-truck-loading text-6xl"></i>
                    </div>
                    <div class="relative z-10">
                        <div class="flex justify-between items-center mb-6">
                            <div>
                                <h3 class="text-xs font-bold text-gray-500 uppercase tracking-widest">Pedido en Curso</h3>
                                <p class="text-xl font-bold text-white">{pedidoActivo.id}</p>
                            </div>
                            <span class="px-3 py-1 bg-primary/10 text-primary border border-primary/20 rounded-full text-xs font-bold animate-pulse">
                                {pedidoActivo.estado}
                            </span>
                        </div>
                        
                        <p class="text-gray-300 text-sm mb-4">{pedidoActivo.descripcion}</p>
                        
                        <div class="space-y-2">
                            <div class="flex justify-between text-xs">
                                <span class="text-gray-500">Progreso de Fabricación</span>
                                <span class="text-white font-bold">{pedidoActivo.progreso}%</span>
                            </div>
                            <div class="w-full h-3 bg-gray-800 rounded-full overflow-hidden">
                                <div class="h-full bg-primary shadow-[0_0_15px_rgba(255,40,0,0.5)] transition-all duration-1000" style={`width: ${pedidoActivo.progreso}%`}></div>
                            </div>
                        </div>

                        <div class="mt-8 flex items-center justify-between pt-6 border-t border-gray-800">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-full bg-gray-800 flex items-center justify-center text-gray-400">
                                    <i class="fas fa-user-tie"></i>
                                </div>
                                <div class="text-xs">
                                    <p class="text-gray-500">Vendedor Asignado</p>
                                    <p class="text-white font-bold">{pedidoActivo.vendedor}</p>
                                </div>
                            </div>
                            <button class="text-xs text-primary font-bold hover:underline">Contactar por WhatsApp</button>
                        </div>
                    </div>
                </div>

                <!-- Historial -->
                <div class="bg-[#1a1a1a] border border-gray-800 rounded-2xl p-6">
                    <h3 class="text-lg font-bold text-white mb-6">Mis Presupuestos Recientes</h3>
                    <div class="space-y-4">
                        {misPresupuestos.map(p => (
                            <div class="flex items-center justify-between p-4 bg-black/30 border border-gray-800 rounded-xl hover:border-gray-600 transition-colors">
                                <div class="flex items-center gap-4">
                                    <div class="w-10 h-10 rounded-lg bg-gray-800 flex items-center justify-center text-primary">
                                        <i class="fas fa-file-invoice-dollar"></i>
                                    </div>
                                    <div>
                                        <p class="text-white font-bold">{p.id} - {p.material}</p>
                                        <p class="text-xs text-gray-500">{p.fecha}</p>
                                    </div>
                                </div>
                                <div class="text-right">
                                    <p class="text-white font-bold">{p.total}</p>
                                    <span class={`text-[10px] font-bold uppercase ${p.estado === 'Entregado' ? 'text-green-500' : 'text-primary'}`}>
                                        {p.estado}
                                    </span>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            </div>

            <!-- Stats & Profile -->
            <div class="space-y-6">
                <div class="bg-gradient-to-br from-[#1a1a1a] to-[#222] border border-gray-800 rounded-2xl p-6">
                    <div class="text-center mb-6">
                        <div class="w-20 h-20 bg-gray-800 rounded-full mx-auto flex items-center justify-center text-3xl font-bold text-primary mb-4 border-2 border-primary/20">
                            CL
                        </div>
                        <h3 class="text-lg font-bold text-white">Carpintería Los Álamos</h3>
                        <p class="text-xs text-gray-400">Socio desde: Enero 2024</p>
                    </div>
                    
                    <div class="grid grid-cols-2 gap-4">
                        <div class="bg-black/40 p-3 rounded-xl border border-gray-800 text-center">
                            <p class="text-[10px] text-gray-500 uppercase font-bold mb-1">Puntos Acum.</p>
                            <p class="text-xl font-bold text-yellow-500">1,240 <i class="fas fa-star text-xs"></i></p>
                        </div>
                        <div class="bg-black/40 p-3 rounded-xl border border-gray-800 text-center">
                            <p class="text-[10px] text-gray-500 uppercase font-bold mb-1">Nivel</p>
                            <p class="text-xl font-bold text-green-500">GOLD</p>
                        </div>
                    </div>
                </div>

                <div class="bg-[#1a1a1a] border border-gray-800 rounded-2xl p-6">
                    <h3 class="text-sm font-bold text-white mb-4">¿NECESITAS AYUDA?</h3>
                    <p class="text-xs text-gray-400 mb-4 leading-relaxed">
                        Nuestro horario de atención es de Lunes a Viernes de 8:00 a 18:00hs. 
                        Sábados de 8:00 a 13:00hs.
                    </p>
                    <button class="w-full py-3 bg-green-600/10 hover:bg-green-600/20 text-green-500 text-sm font-bold rounded-xl transition-all flex items-center justify-center gap-2">
                        <i class="fab fa-whatsapp"></i> HABLAR CON SOPORTE
                    </button>
                </div>
            </div>

        </div>
    </div>
</Layout>
