---
import AdminLayout from '../../layouts/AdminLayout.astro';

// Datos estáticos base (Mock) para Vendedores
const vendedores = [
    { id: 1, nombre: "Martín Giménez", rol: "Vendedor Sr.", ventasMes: 45, sucursal: "Villa Tesei", estado: "Activo" },
    { id: 2, nombre: "Laura Sánchez", rol: "Vendedor", ventasMes: 32, sucursal: "Hurlingham", estado: "Activo" },
    { id: 3, nombre: "Carlos Rodriguez", rol: "Vendedor Jr.", ventasMes: 15, sucursal: "Villa Tesei", estado: "Vacaciones" },
];
---

<AdminLayout title="Gestión de Vendedores">
    
    <div class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <h2 class="text-3xl font-bold text-white mb-2">Equipo de Ventas</h2>
            <p class="text-gray-400">Administración de usuarios vendedores autorizados por ti.</p>
        </div>
        <div class="flex gap-3">
            <button class="px-4 py-2 bg-primary hover:bg-primary-light text-white rounded-lg transition-colors shadow-[0_0_15px_rgba(255,40,0,0.3)] flex items-center gap-2 font-bold">
                <i class="fas fa-user-plus"></i> Nuevo Vendedor
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        
        <!-- Lista de Vendedores -->
        <div class="lg:col-span-2 space-y-4">
            {vendedores.map(v => (
                <div class="bg-[#1a1a1a] border border-gray-800 rounded-xl p-5 flex flex-col sm:flex-row items-center justify-between gap-4 hover:border-gray-600 transition-colors group">
                    <div class="flex items-center gap-4 w-full sm:w-auto">
                        <div class="w-14 h-14 rounded-full bg-gray-800 flex items-center justify-center text-gray-500 text-xl font-bold relative shrink-0">
                            {v.nombre.charAt(0)}
                            <div class={`absolute bottom-0 right-0 w-4 h-4 rounded-full border-2 border-[#1a1a1a] ${v.estado === 'Activo' ? 'bg-green-500' : 'bg-yellow-500'}`}></div>
                        </div>
                        <div>
                            <h3 class="text-lg font-bold text-white leading-tight">{v.nombre}</h3>
                            <p class="text-sm text-gray-400">{v.rol} • {v.sucursal}</p>
                        </div>
                    </div>
                    
                    <div class="flex items-center justify-between w-full sm:w-auto gap-6 sm:gap-8">
                        <div class="text-center">
                            <p class="text-xs text-gray-500 uppercase font-semibold">Ventas este Mes</p>
                            <p class="text-xl font-bold text-white">{v.ventasMes}</p>
                        </div>
                        <div class="flex gap-2">
                             <button class="w-10 h-10 rounded-lg bg-white/5 hover:bg-white/10 text-gray-400 hover:text-white flex items-center justify-center transition-colors" title="Ver Métrica Completa">
                                <i class="fas fa-chart-line"></i>
                            </button>
                            <button class="w-10 h-10 rounded-lg bg-white/5 hover:bg-white/10 text-gray-400 hover:text-primary flex items-center justify-center transition-colors" title="Editar Permisos">
                                <i class="fas fa-cog"></i>
                            </button>
                        </div>
                    </div>
                </div>
            ))}
        </div>

        <!-- Resumen Lateral -->
        <div class="space-y-6">
            <div class="bg-[#1a1a1a] border border-gray-800 rounded-xl p-6">
                <h3 class="text-lg font-bold text-white mb-4 border-b border-gray-800 pb-3">Resumen del Equipo</h3>
                <div class="space-y-3">
                    <div class="flex justify-between items-center text-sm">
                        <span class="text-gray-400">Total Vendedores</span>
                        <span class="text-white font-bold">3</span>
                    </div>
                    <div class="flex justify-between items-center text-sm">
                        <span class="text-gray-400">Activos Actualmente</span>
                        <span class="text-green-400 font-bold">2</span>
                    </div>
                    <div class="flex justify-between items-center text-sm">
                        <span class="text-gray-400">Roles de Administrador</span>
                        <span class="text-primary font-bold">1 (Tú)</span>
                    </div>
                </div>
            </div>

            <div class="bg-gradient-to-br from-[#1a1a1a] to-[#222222] border border-gray-800 rounded-xl p-6 relative overflow-hidden">
                <div class="absolute -right-4 -bottom-4 w-24 h-24 bg-primary/10 rounded-full blur-xl"></div>
                <div class="relative z-10 flex flex-col gap-3">
                    <div class="w-10 h-10 rounded-full bg-primary/20 text-primary flex items-center justify-center">
                        <i class="fas fa-info-circle text-lg"></i>
                    </div>
                    <h3 class="text-md font-bold text-white">Sobre los Roles</h3>
                    <p class="text-xs text-gray-400 leading-relaxed">
                        Los vendedores solo pueden ver y gestionar pedidos, crear presupuestos rápidos y registrar clientes. <strong>No pueden</strong> modificar catálogos, actualizar precios ni borrar usuarios. Esta función es exclusiva para el Administrador General (Javier).
                    </p>
                </div>
            </div>
        </div>

    </div>

</AdminLayout>
