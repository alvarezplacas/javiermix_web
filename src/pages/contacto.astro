---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

const title = "Contacto | Alvarez Placas";
const sucursales = [
    {
        nombre: "Casa Central - Villa Tesei",
        direccion: "Av. Vergara 1605, Hurlingham",
        telefono: "+54 11 1234-5678",
        horario: "Lun a Vie: 8:00 a 17:00 | Sáb: 8:00 a 13:00",
        whatsapp: "5491112345678",
        maps: "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3283.473528766524!2d-58.6366!3d-34.6152!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzTCsDM2JzU0LjciUyA1OMKwMzgnMTEuNyJX!5e0!3m2!1ses!2sar!4v1700000000000"
    }
];
---

<Layout title={title}>
    <Header />

    <main class="min-h-screen pt-28 pb-20 px-4">
        <div class="max-w-7xl mx-auto">
            
            <!-- Hero Section Contacto -->
            <div class="text-center mb-16">
                <h1 class="text-4xl md:text-6xl font-extrabold text-white mb-6 tracking-tight">
                    Estamos para <span class="text-primary italic">ayudarte</span>
                </h1>
                <p class="text-gray-400 text-lg max-w-2xl mx-auto">
                    ¿Tenés dudas sobre tu pedido o necesitás asesoramiento técnico? Contactanos por cualquiera de nuestros canales oficiales.
                </p>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
                
                <!-- Columna Izquierda: Información de contacto -->
                <div class="space-y-8">
                    {sucursales.map(s => (
                        <div class="bg-[#1a1a1a] border border-white/10 rounded-3xl p-8 shadow-2xl relative overflow-hidden group">
                            <div class="absolute -right-10 -top-10 w-40 h-40 bg-primary/5 rounded-full blur-3xl transition-all group-hover:bg-primary/10"></div>
                            
                            <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
                                <i class="fas fa-location-dot text-primary"></i> {s.nombre}
                            </h2>

                            <div class="space-y-6 text-gray-300">
                                <div class="flex items-start gap-4">
                                    <div class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center shrink-0">
                                        <i class="fas fa-map-marker-alt text-primary-light"></i>
                                    </div>
                                    <div>
                                        <p class="font-semibold text-white">Dirección</p>
                                        <p>{s.direccion}</p>
                                    </div>
                                </div>

                                <div class="flex items-start gap-4">
                                    <div class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center shrink-0">
                                        <i class="fas fa-clock text-blue-400"></i>
                                    </div>
                                    <div>
                                        <p class="font-semibold text-white">Horarios de Atención</p>
                                        <p>{s.horario}</p>
                                    </div>
                                </div>

                                <div class="flex items-start gap-4">
                                    <div class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center shrink-0">
                                        <i class="fas fa-phone text-green-400"></i>
                                    </div>
                                    <div>
                                        <p class="font-semibold text-white">Teléfonos</p>
                                        <p>{s.telefono}</p>
                                    </div>
                                </div>
                            </div>

                            <div class="mt-8 flex flex-wrap gap-4">
                                <a href={`https://wa.me/${s.whatsapp}`} class="flex-1 min-w-[180px] py-4 bg-green-600 hover:bg-green-500 text-white font-bold rounded-2xl flex items-center justify-center gap-3 transition-all shadow-[0_0_20px_rgba(22,163,74,0.3)]">
                                    <i class="fab fa-whatsapp text-xl"></i> WhatsApp Directo
                                </a>
                                <a href="#formulario" class="flex-1 min-w-[180px] py-4 bg-white/5 hover:bg-white/10 text-white border border-white/20 font-bold rounded-2xl flex items-center justify-center gap-3 transition-all">
                                    <i class="fas fa-paper-plane"></i> Enviar Email
                                </a>
                            </div>
                        </div>
                    ))}

                    <!-- Mapa (Iframe) -->
                    <div class="rounded-3xl overflow-hidden border border-white/10 h-80 shadow-2xl">
                        <iframe 
                            src={sucursales[0].maps}
                            width="100%" 
                            height="100%" 
                            style="border:0; filter: grayscale(1) invert(0.9) contrast(1.2);" 
                            allowfullscreen="" 
                            loading="lazy">
                        </iframe>
                    </div>
                </div>

                <!-- Columna Derecha: Formulario -->
                <div id="formulario" class="bg-[#1a1a1a]/50 backdrop-blur-xl border border-white/10 rounded-3xl p-8 md:p-10 shadow-2xl">
                    <h3 class="text-2xl font-bold text-white mb-2">Escribinos</h3>
                    <p class="text-gray-400 mb-8">Completá el formulario y un asesor se contactará con vos a la brevedad.</p>

                    <form class="space-y-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="space-y-2">
                                <label class="text-sm font-semibold text-gray-400 ml-1">Nombre Completo</label>
                                <input type="text" placeholder="Tu nombre..." class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-4 text-white focus:outline-none focus:border-primary/50 transition-colors" />
                            </div>
                            <div class="space-y-2">
                                <label class="text-sm font-semibold text-gray-400 ml-1">Email</label>
                                <input type="email" placeholder="tu@email.com" class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-4 text-white focus:outline-none focus:border-primary/50 transition-colors" />
                            </div>
                        </div>

                        <div class="space-y-2">
                            <label class="text-sm font-semibold text-gray-400 ml-1">Asunto</label>
                            <select class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-4 text-white focus:outline-none focus:border-primary/50 transition-colors appearance-none">
                                <option>Consulta sobre Pedido</option>
                                <option>Presupuesto Especial</option>
                                <option>Reclamo / Sugerencia</option>
                                <option>Otro</option>
                            </select>
                        </div>

                        <div class="space-y-2">
                            <label class="text-sm font-semibold text-gray-400 ml-1">Mensaje</label>
                            <textarea rows="5" placeholder="¿En qué podemos ayudarte?" class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-4 text-white focus:outline-none focus:border-primary/50 transition-colors resize-none"></textarea>
                        </div>

                        <button type="submit" class="w-full py-4 bg-primary text-white font-extrabold text-lg rounded-2xl shadow-[0_0_25px_rgba(255,40,0,0.4)] hover:shadow-[0_0_35px_rgba(255,40,0,0.6)] hover:-translate-y-1 transition-all">
                            Enviar Mensaje <i class="fas fa-chevron-right ml-2 text-sm"></i>
                        </button>
                    </form>
                </div>

            </div>
        </div>
    </main>
</Layout>

<style>
    /* Estilo para los select options en Firefox/Chrome */
    select option {
        background: #1a1a1a;
        color: white;
    }
</style>
