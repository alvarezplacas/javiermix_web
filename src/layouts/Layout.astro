---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';
import MobileNav from '../components/MobileNav.astro';
import SEO from '../components/SEO.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article' | 'profile';
  url?: string;
  pubDate?: string;
  author?: string;
  keywords?: string[];
  noindex?: boolean;
  schema?: object;
}

const {
  title,
  description,
  image,
  type,
  url = Astro.url.pathname,
  pubDate,
  author,
  keywords,
  noindex,
  schema,
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<!-- ══ SEO Sistema Centralizado ══ -->
		<SEO
			title={title}
			description={description}
			image={image}
			type={type}
			url={url}
			pubDate={pubDate}
			author={author}
			keywords={keywords}
			noindex={noindex}
			schema={schema}
		/>

		<!-- ══ Google Fonts ══ -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">

		<!-- ══ Font Awesome ══ -->
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />

		<ViewTransitions />
	</head>
	<body>
		<slot />
		<MobileNav />
	</body>
</html>

<style is:global>
	html {
		scroll-behavior: smooth;
	}
	body {
		margin: 0;
		padding: 0;
	}
</style>
