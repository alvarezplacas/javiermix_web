  title: string;
  activeTab: 'dashboard' | 'obras' | 'revista' | 'clientes' | 'certificados';
}

const { title, activeTab } = Astro.props;

const navItems = [
  { id: 'dashboard',      label: 'Dashboard',       href: '/admin',              icon: 'fa-chart-line',   group: 'main' },
  { id: 'obras',          label: 'Gestión de Obras', href: '/admin/obras',        icon: 'fa-images',       group: 'main' },
  { id: 'revista',        label: 'Revista Online',   href: '/admin/revista',      icon: 'fa-newspaper',    group: 'main' },
  { id: 'clientes',       label: 'CRM / Clientes',   href: '/admin/coleccionistas', icon: 'fa-users',        group: 'main' },
  { id: 'certificados',   label: 'Certificados',     href: '/admin/certificados', icon: 'fa-certificate',  group: 'main' },
  { id: 'marketing',      label: 'Marketing',        href: '/admin/marketing',    icon: 'fa-bullhorn',     group: 'main' },
];
