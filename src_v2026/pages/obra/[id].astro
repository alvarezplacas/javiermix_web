---
import { db } from '../../db/client';
import { artworks } from '../../db/schema';
import { eq, inArray } from 'drizzle-orm';
import fs from 'node:fs';
import path from 'node:path';
import { loadArtworkMetadata } from '../../utils/metadata.js';
import ExifReader from 'exifreader';
import FramingStudio from '../../components/FramingStudio.astro';

export const prerender = false;

const { id } = Astro.params;

const seriesPath = path.join(process.cwd(), 'public', 'img', 'Series');
let artworkData = null;

if (id && fs.existsSync(seriesPath)) {
    const folders = fs.readdirSync(seriesPath).filter(file => fs.statSync(path.join(seriesPath, file)).isDirectory());
    const metadataMap = loadArtworkMetadata();

    find_artwork: for (const folder of folders) {
        const folderSlug = folder.replace(/_/g, '-').toLowerCase();
        if (!id.startsWith(folderSlug + '-')) continue;

        const folderPath = path.join(seriesPath, folder);
        const allItems = fs.readdirSync(folderPath).filter(f => /\.(avif|jpg|jpeg|png)$/i.test(f));
        
        // Scan main images
        const mainImages = allItems.filter(f => {
            const low = f.toLowerCase();
            return (low.startsWith('jmx_') || low.startsWith('jmix_')) && !/_(\d+)\.(avif|jpg|jpeg|png)$/i.test(low);
        });

        // 1. Check DB first for all files in this series to find a title match
        const dbSeriesArtworks = mainImages.length > 0 
            ? await db.select().from(artworks).where(inArray(artworks.filename, mainImages))
            : [];
        const dbMap = new Map(dbSeriesArtworks.map(r => [r.filename, r]));

        for (const f of mainImages) {
            const dbMeta = dbMap.get(f);
            const csvMeta = metadataMap.get(f);
            
            // Potential titles for this file
            let titlesToTry = new Set();
            if (dbMeta?.title) titlesToTry.add(dbMeta.title);
            if (csvMeta?.title) titlesToTry.add(csvMeta.title);
            titlesToTry.add(f.split('.')[0].replace(/_/g, ' '));
            
            // Try EXIF titles too
            try {
                const tags = await ExifReader.load(path.join(folderPath, f));
                if (tags['Headline']?.description) titlesToTry.add(tags['Headline'].description);
                if (tags['ObjectName']?.description) titlesToTry.add(tags['ObjectName'].description);
                if (tags['Title']?.description) titlesToTry.add(tags['Title'].description);
            } catch(e) {}

            for (let t of titlesToTry) {
                const cleanTitle = t.toLowerCase().trim().replace(/\s+/g, '-');
                const candidateId = `${folderSlug}-${cleanTitle}`;

                if (candidateId === id) {
                    // ENCONTRADO
                    const serieName = folder.replace(/_/g, ' ').toUpperCase();
                    const baseName = f.split('.')[0].toLowerCase();
                    const contextImages = allItems.filter(img => {
                        const fLow = img.toLowerCase();
                        return fLow !== f.toLowerCase() && fLow.startsWith(baseName + '_') && /_(\d+)\.(avif|jpg|jpeg|png)$/i.test(fLow);
                    });

                    let fiche = null;
                    if (dbMeta) {
                        fiche = {
                            story: dbMeta.description || '',
                            camera: dbMeta.camera || '',
                            lens: dbMeta.lens || '',
                            year: dbMeta.date || '',
                            author: 'Javier Mix'
                        };
                    } else {
                        try {
                            const tags = await ExifReader.load(path.join(folderPath, f));
                            const description = tags['Caption/Abstract']?.description || tags['Description']?.description;
                            const creator = tags['By-line']?.description || tags['Creator']?.description || 'Javier Mix';
                            if (description || tags['Model']?.description) {
                                fiche = {
                                    story: description || '',
                                    camera: tags['Model']?.description || '',
                                    lens: tags['LensModel']?.description || '',
                                    iso: tags['ISOSpeedRatings']?.description || tags['ISO']?.value?.toString() || '',
                                    shutterspeed: tags['ExposureTime']?.description || '',
                                    aperture: tags['FNumber']?.description ? `f/${tags['FNumber'].description}` : '',
                                    year: tags['DateCreated']?.description ? tags['DateCreated'].description.substring(0,4) || '' : '',
                                    location: tags['City']?.description || '',
                                    author: creator
                                };
                            }
                        } catch(e) {}
                    }

                    const sizes = [];
                    if (dbMeta) {
                        if (dbMeta.precio_small) sizes.push({ label: 'Small', dimensions: '20 x 30 cm', price: dbMeta.precio_small });
                        if (dbMeta.precio_medium) sizes.push({ label: 'Medium', dimensions: '40 x 60 cm', price: dbMeta.precio_medium });
                        if (dbMeta.precio_large) sizes.push({ label: 'Large', dimensions: '60 x 90 cm', price: dbMeta.precio_large });
                    } else if (csvMeta) {
                        if (csvMeta.precio_small) sizes.push({ label: 'Small', dimensions: csvMeta.size_small || '20 x 30 cm', price: csvMeta.precio_small });
                        if (csvMeta.precio_medium) sizes.push({ label: 'Medium', dimensions: csvMeta.size_medium || '40 x 60 cm', price: csvMeta.precio_medium });
                        if (csvMeta.precio_large) sizes.push({ label: 'Large', dimensions: csvMeta.size_large || '60 x 90 cm', price: csvMeta.precio_large });
                    }

                    artworkData = {
                        title: dbMeta?.title || t,
                        serieName,
                        coverImage: `/img/Series/${folder}/${f}`,
                        roomImage: contextImages.length > 0 ? `/img/Series/${folder}/${contextImages[0]}` : null,
                        contextImages: contextImages.map(img => `/img/Series/${folder}/${img}`),
                        precio: sizes.length > 0 ? sizes[0].price : 250,
                        etiqueta: "Fine Art Print",
                        meta: csvMeta || null,
                        fiche,
                        sizes
                    };
                    break find_artwork;
                }
            }
        }
    }
}

if (!artworkData) {
    return Astro.redirect('/galeria');
}

const { title, serieName, coverImage, roomImage, precio, etiqueta, meta, fiche, sizes = [] } = artworkData;


// Phone format for WhatsApp link
const whatsappNumber = "5491100000000"; // Replace con el real luego
const waLink = `https://wa.me/${whatsappNumber}?text=Hola,%20estoy%20interesado%20en%20adquirir%20la%20obra%20${encodeURIComponent(title)}%20de%20la%20colección%20${encodeURIComponent(serieName)}.`;
---

<Layout title={`${title} | Obra Fine Art`}>
  <Header currentPath="/galeria" />

  <article class="obra-container">
    <div class="split-layout">
      
      <!-- Columna Izquierda: Imagen Interactiva -->
      <section class="image-column">
        <div class="sticky-image-container">
          <div class="image-wrapper">
            <img src={coverImage} alt={`Obra ${title}`} class="main-artwork" id="primary-image" />
            {roomImage && (
              <img src={roomImage} alt={`Vista en Ambiente de ${title}`} class="room-artwork" id="secondary-image" />
            )}
          </div>
          
          <div class="image-controls">
            {roomImage ? (
               <button class="control-btn active" id="btn-obra">VER EN SALA</button>
            ) : (
               <button class="control-btn" style="opacity: 0.3; cursor: not-allowed;" disabled>SIN VISTA EN SALA</button>
            )}
            <button class="control-btn" id="btn-3d">VER EN 3D</button>
            <button class="control-btn" id="btn-marco">PROBAR MARCO</button>
          </div>
          
          <div class="share-controls">
            <span>COMPARTIR:</span>
            <div class="social-icons">
               <i class="fab fa-whatsapp"></i>
               <i class="fab fa-x-twitter"></i>
               <i class="fab fa-facebook-f"></i>
               <i class="fab fa-instagram"></i>
            </div>
          </div>
        </div>
      </section>

      <!-- Columna Derecha: Información y Venta -->
      <section class="info-column">
        <a href={`/galeria/${coverImage.split('/')[3]}`} class="back-link">← VOLVER A {serieName}</a>
        
        <div class="serie-label">SERIE: {serieName}</div>
        <h1 class="obra-title">{title}</h1>
        
        <div class="tags-container">
          {etiqueta && <span class="tag-accent">{etiqueta}</span>}
          <span class="tag-outline">CERTIFICADO DE AUTENTICIDAD</span>
          <span class="tag-outline">CALIDAD MUSEO</span>
        </div>
        
        <hr class="divider" />
        
        <!-- Tabs de información -->
        <div class="tabs-header">
          <button class="tab-btn active" data-target="historia">HISTORIA</button>
          <button class="tab-btn" data-target="ficha">FICHA TÉCNICA</button>
          <button class="tab-btn" data-target="terminos">TÉRMINOS</button>
        </div>
        
        <div class="tab-content" id="tab-historia" style="display: block;">
          <div class="prose-content">
            <h2 class="prose-title">La Historia detrás de la Imagen</h2>
            {fiche?.story ? (
              <p>{fiche.story}</p>
            ) : meta?.description ? (
              <p>{meta.description}</p>
            ) : (
              <p>Esta pieza de autor es parte de una selección curada rigurosamente. Refleja nuestro compromiso con el legado fotográfico y el diseño contemporáneo, donde cada textura, sombra y captura de luz está cuidada bajo los más altos estándares Fine Art.</p>
            )}
            <p>La edición es estricta y controlada, asegurando el valor de obra única a lo largo del tiempo.</p>
          </div>
        </div>

        <div class="tab-content" id="tab-ficha" style="display: none;">
          <div class="technical-grid">
            <div class="tech-section">
              <h3 class="tech-category">THE PRINT (CALIDAD MUSEO)</h3>
              <ul class="tech-list">
                <li><i class="fas fa-scroll"></i> {meta?.paper || 'Papel Algodón 100% (Hahnemühle)'}</li>
                <li><i class="fas fa-expand-arrows-alt"></i> Dimensiones: {meta?.dimensions || 'A convenir'}</li>
                <li><i class="fas fa-certificate"></i> Certificado de Autenticidad</li>
                <li><i class="fas fa-infinity"></i> Pigmentos Minerales (+100 Años)</li>
              </ul>
            </div>
            
            <div class="tech-section">
              <h3 class="tech-category">THE SHOT (DATOS TÉCNICOS)</h3>
              <div class="shot-data-grid">
                <div class="shot-item">
                   <i class="fas fa-camera"></i>
                   <span class="label">CÁMARA</span>
                   <span class="value">{fiche?.camera || meta?.camera || 'Nikon Fine Art'}</span>
                </div>
                <div class="shot-item">
                   <i class="fas fa-circle-notch"></i>
                   <span class="label">LENTE</span>
                   <span class="value">{fiche?.lens || meta?.lens || 'Finesse Optics'}</span>
                </div>
                <div class="shot-item">
                   <i class="fas fa-calendar-alt"></i>
                   <span class="label">FECHA</span>
                   <span class="value">{fiche?.year || meta?.date || '2024'}</span>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <div class="tab-content" id="tab-terminos" style="display: none;">
          <div class="legal-content">
            <p>Información detallada sobre el proceso de adquisición, envíos y autenticidad disponible en la sección de <strong>Condiciones de Venta</strong> más abajo.</p>
          </div>
        </div>
        
        <hr class="divider" />

        <!-- Selector de Tamaño -->
        {sizes.length > 0 && (
          <div class="size-selector-section">
            <span class="size-selector-label">SELECCIONA TAMAÑO:</span>
            <div class="size-options" id="size-options">
              {sizes.map((s, i) => (
                <button
                  class={`size-option${i === 0 ? ' active' : ''}`}
                  data-price={s.price}
                  data-dimensions={s.dimensions}
                  data-label={s.label}
                >
                  <span class="size-dimensions">{s.dimensions}</span>
                  <span class="size-label-text">{s.label}</span>
                </button>
              ))}
            </div>
          </div>
        )}

        <!-- Canvas Material Info (aparece solo al seleccionar Large) -->
        <div class="canvas-info" id="canvas-info" aria-live="polite">
          <div class="canvas-info-inner">
            <span class="canvas-badge">GRAN FORMATO · EDICIÓN LIMITADA</span>
            <h4 class="canvas-title">Canson Museum Pro Canvas · 385 g/m²</h4>
            <p class="canvas-body">
              El formato Grande se imprime sobre un canvas <strong>100% algodón libre de ácidos</strong>, pensado para durar décadas sin perder ni un tono. Su textura profunda añade presencia táctil a cada imagen —el óxido, el metal, la luz capturada cobran un relieve que el papel no puede igualar. El acabado mate resistente al agua elimina la necesidad de vidrio: sin reflejos, la obra habla directamente al espectador. Con 385 g de gramaje, la pieza adquiere cuerpo y solidez de objeto de arte. Cada ejemplar se entrega firmado: <em>Javier Mix pinxit</em>.
            </p>
          </div>
        </div>
        
        <!-- Checkout Area -->
        <div class="checkout-area">
          <div class="price-box">
             <span class="price-label">PRECIO</span>
             <div class="price-value">
               <span class="number" id="price-display">{precio}</span>
               <span class="currency">U$D</span>
             </div>
          </div>
          
          <div class="action-buttons">
             <button class="btn-buy" id="btn-buy-link">
               AGREGAR AL CARRITO
             </button>
             
             <div class="secondary-actions">
                <button class="btn-favorite" id="btn-like" aria-label="Añadir a favoritos" data-filename={coverImage.split('/').pop()} data-serie={serieName} data-title={title}>
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" id="heart-icon" class="heart-svg"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                  <span class="like-label">ME GUSTA</span>
                  <span id="like-count" class="like-number">0</span>
                </button>
                <button class="btn-collection">
                   AGREGAR A MINI COLECCIÓN
                </button>
             </div>
          </div>
        <!-- Se hace la venta: Persistente y visible -->
        <div class="sales-info-card">
          <h3 class="sales-card-title"><i class="fas fa-handshake"></i> CONDICIONES DE VENTA / JHM</h3>
          <div class="sales-card-grid">
             <div class="sales-item">
                <span class="sales-label">EL PRODUCTO</span>
                <p>Impresión Fine Art de alta gama. Pigmentos minerales (+100 años). Papel Algodón o Canvas Pro.</p>
             </div>
             <div class="sales-item">
                <span class="sales-label">ENMARCADO</span>
                <p>La obra se entrega como lámina. No incluye marco (coordinar por Studio Enmarcado).</p>
             </div>
             <div class="sales-item">
                <span class="sales-label">ENVÍO</span>
                <p>No incluido. Se coordina de forma privada post-compra para asegurar integridad de la obra.</p>
             </div>
             <div class="sales-item">
                <span class="sales-label">AUTENTICIDAD</span>
                <p>Todas las piezas se entregan firmadas (Javier Mix pinxit) y con Certificado de Autenticidad.</p>
             </div>
          </div>
        </div>

      </section>

    </div>
  </article>

  <FramingStudio imageSrc={coverImage} title={title} />
</Layout>

<script>
  import { addCartItem } from '../../store/cartStore';

  // standard 2026: astro:page-load for View Transitions compatibility
  document.addEventListener('astro:page-load', () => {

    // E-Commerce Logic: Add to Cart
    const btnBuy = document.getElementById('btn-buy-link') as HTMLButtonElement | null;
    if (btnBuy) {
      btnBuy.addEventListener('click', (e) => {
        e.preventDefault();
        
        const activeSizeBtn = document.querySelector('.size-option.active');
        let price = 250;
        let sizeLabel = 'Standard';
        let dimensions = '20 x 30 cm';
        
        if (activeSizeBtn) {
            price = parseInt(activeSizeBtn.getAttribute('data-price') || '0');
            sizeLabel = activeSizeBtn.getAttribute('data-label') || '';
            dimensions = activeSizeBtn.getAttribute('data-dimensions') || '';
        }
        
        const artworkId = window.location.pathname.split('/').filter(Boolean).pop() || 'unknown';
        const titleEl = document.querySelector('.obra-title');
        const title = titleEl ? (titleEl as HTMLElement).innerText : 'Obra Fine Art';
        
        const imgEl = document.getElementById('primary-image');
        const coverImage = imgEl ? imgEl.getAttribute('src') || '' : '';

        addCartItem({
          artworkId,
          title,
          size: `${sizeLabel} (${dimensions})`,
          price,
          image: coverImage
        });

        // Visual Feedback
        const originalText = btnBuy.innerHTML;
        btnBuy.innerHTML = "¡AGREGADO AL CARRITO!";
        btnBuy.style.backgroundColor = "#4a9e6a";
        btnBuy.style.color = "white";
        
        // Dispatch event for Cart Drawer to listen
        document.dispatchEvent(new CustomEvent('cartUpdated'));
        
        setTimeout(() => { 
            btnBuy.innerHTML = originalText;
            btnBuy.style.backgroundColor = "var(--color-accent)";
            btnBuy.style.color = "var(--color-onyx-deep)";
        }, 1500);
      });
    }

    // Tabs Logic
    const tabBtns = document.querySelectorAll('.tab-btn');
    const tabContents = document.querySelectorAll('.tab-content');
    
    function switchTab(btn) {
        const targetId = btn.getAttribute('data-target');
        
        // Update Buttons
        tabBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        
        // Update Contents
        tabContents.forEach(c => {
            const content = c as HTMLElement;
            if (content.id === `tab-${targetId}`) {
                content.style.display = 'block';
                content.classList.add('fade-in-content');
                setTimeout(() => content.classList.remove('fade-in-content'), 600);
            } else {
                content.style.display = 'none';
            }
        });
    }

    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => switchTab(btn));
    });

    // Room view hover simulate
    const btnObra = document.getElementById('btn-obra');
    const imgPrim = document.getElementById('primary-image');
    const imgSec = document.getElementById('secondary-image');
    
    if(btnObra && imgPrim && imgSec) {
        btnObra.addEventListener('mouseenter', () => {
             imgPrim.style.opacity = '0';
             imgSec.style.opacity = '1';
        });
        btnObra.addEventListener('mouseleave', () => {
             imgPrim.style.opacity = '1';
             imgSec.style.opacity = '0';
        });
    }

    // Framing Studio Trigger
    const btnMarco = document.getElementById('btn-marco');
    const studio = document.getElementById('framing-studio');
    
    if (btnMarco && studio) {
      btnMarco.addEventListener('click', () => {
        studio.style.display = 'block';
        document.body.style.overflow = 'hidden'; // Bloquear scroll
      });
    }

    // VER EN 3D Trigger
    const btn3D = document.getElementById('btn-3d');

    if (btn3D && studio) {
      btn3D.addEventListener('click', () => {
        studio.style.display = 'block';
        document.body.style.overflow = 'hidden';
        
        // Use the new global function defined in FramingStudio
        if ((window as any).activate3DInStudio) {
            (window as any).activate3DInStudio();
        }
      });
    }

    // Smart Orientation Detection Algorithm
    const primaryImg = document.getElementById('primary-image') as HTMLImageElement;
    const wrapper = document.querySelector('.image-wrapper');

    function updateOrientation() {
      if (!primaryImg || !wrapper) return;
      const isPortrait = primaryImg.naturalHeight > primaryImg.naturalWidth;
      wrapper.classList.toggle('is-portrait', isPortrait);
      wrapper.classList.toggle('is-landscape', !isPortrait);
    }

    if (primaryImg) {
      if (primaryImg.complete) updateOrientation();
      else primaryImg.addEventListener('load', updateOrientation);
    }

    // Unified Move Handler (Mouse & Touch)
    function handleMove(e: any) {
      if (!wrapper || !primaryImg) return;
      
      const clientX = e.touches ? e.touches[0].clientX : e.clientX;
      const clientY = e.touches ? e.touches[0].clientY : e.clientY;
      
      const { left, top, width, height } = wrapper.getBoundingClientRect();
      const x = (clientX - left) / width;
      const y = (clientY - top) / height;

      // Master-level refinement: High magnification (1.6x) for detail inspection
      const moveX = (x - 0.5) * -60; // Inverted and increased for "panning" feel
      const moveY = (y - 0.5) * -60;
      
      primaryImg.style.transition = 'transform 0.2s cubic-bezier(0.23, 1, 0.32, 1), opacity 0.8s ease';
      primaryImg.style.transform = `scale(1.6) translate(${moveX}px, ${moveY}px)`;
    }

    function handleReset() {
      if (!primaryImg) return;
      primaryImg.style.transition = 'transform 0.8s cubic-bezier(0.165, 0.84, 0.44, 1), opacity 0.8s ease';
      primaryImg.style.transform = `scale(1) translate(0, 0)`;
    }

    if (wrapper) {
      wrapper.addEventListener('mousemove', handleMove);
      wrapper.addEventListener('mouseleave', handleReset);
      
      // Mobile Touch Support
      wrapper.addEventListener('touchmove', (e) => {
        handleMove(e);
        // Prevent scroll when interacting with the artwork
        if (e.cancelable) e.preventDefault();
      }, { passive: false });
      
      wrapper.addEventListener('touchend', handleReset);
    }

    // Size Selector Logic
    const sizeOptions = document.querySelectorAll('.size-option');
    const priceDisplay = document.getElementById('price-display');
    const btnBuyLink = document.getElementById('btn-buy-link');
    const baseWaLink = btnBuyLink ? btnBuyLink.getAttribute('href') : '';

    const canvasInfo = document.getElementById('canvas-info');

    function selectSize(btn: HTMLElement) {
      sizeOptions.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const price = btn.getAttribute('data-price') || '';
      const dimensions = btn.getAttribute('data-dimensions') || '';
      const label = btn.getAttribute('data-label') || '';

      // Update displayed price
      if (priceDisplay && price) {
        priceDisplay.textContent = price;
        priceDisplay.classList.add('price-pop');
        setTimeout(() => priceDisplay.classList.remove('price-pop'), 400);
      }

      // Update WhatsApp link to include selected size
      if (btnBuyLink && baseWaLink) {
        const sizeText = encodeURIComponent(` — Tamaño: ${dimensions} (${label})`);
        btnBuyLink.setAttribute('href', baseWaLink + sizeText);
      }

      // Show canvas info only for Large
      if (canvasInfo) {
        if (label === 'Large') {
          canvasInfo.classList.add('visible');
        } else {
          canvasInfo.classList.remove('visible');
        }
      }
    }

    sizeOptions.forEach((btn) => {
      btn.addEventListener('click', () => selectSize(btn as HTMLElement));
    });

    // Set first size as default if available
    if (sizeOptions.length > 0) {
      selectSize(sizeOptions[0] as HTMLElement);
    }

    // Likes Logic 2026
    const btnLike = document.getElementById('btn-like');
    const likeCount = document.getElementById('like-count');
    const heartIcon = document.getElementById('heart-icon');
    
    if (btnLike && likeCount && heartIcon) {
        const filename = btnLike.getAttribute('data-filename');
        const serie = btnLike.getAttribute('data-serie');
        const title = btnLike.getAttribute('data-title');

        // Initial load of likes
        fetch(`/api/public/like-artwork?filename=${encodeURIComponent(filename || '')}`)
            .then(res => res.json())
            .then(data => {
                if (data.likes !== undefined) {
                    likeCount.textContent = data.likes;
                }
                if (data.hasLiked) {
                    btnLike.classList.add('liked');
                }
            })
            .catch(() => console.log('Error fetching likes'));

        btnLike.addEventListener('click', async () => {
             if (btnLike.getAttribute('disabled')) return;
             
             // Visual feedback optimistic
             const isAlreadyLiked = btnLike.classList.contains('liked');
             btnLike.classList.toggle('liked');
             btnLike.setAttribute('disabled', 'true');
             btnLike.style.opacity = '0.5';
             btnLike.style.cursor = 'wait';
             
             let current = parseInt(likeCount.textContent || '0');
             likeCount.textContent = (isAlreadyLiked ? Math.max(0, current - 1) : current + 1).toString();
             
             try {
                const res = await fetch('/api/public/like-artwork', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ filename, serie_id: serie, title })
                });
                const data = await res.json();
                if (data.likes !== undefined) {
                    likeCount.textContent = data.likes;
                }
                if (data.hasLiked) {
                    btnLike.classList.add('liked');
                } else {
                    btnLike.classList.remove('liked');
                }
             } catch (e) {
                console.error('Error liking:', e);
                // Rollback visual on error
                btnLike.classList.toggle('liked', isAlreadyLiked);
                likeCount.textContent = current.toString();
             } finally {
                btnLike.removeAttribute('disabled');
                btnLike.style.opacity = '1';
                btnLike.style.cursor = 'pointer';
             }
        });
    }
  });
</script>

