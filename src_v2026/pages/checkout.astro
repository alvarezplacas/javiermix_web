---
// src/pages/checkout.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Checkout | Secure Booking">
  <Header currentPath="" />

  <main class="checkout-main">
    <div class="checkout-grid">
      
      <!-- Columna Izquierda: Formulario -->
      <section class="checkout-form-section">
        <h1 class="checkout-title">Datos de Adquisición</h1>
        <p class="checkout-subtitle">Por favor complete sus datos para procesar la orden y coordinar el envío seguro (Fine Art Logistics).</p>
        
        <form id="checkout-form" class="checkout-form">
          <div class="form-group row">
            <input type="text" name="firstName" placeholder="NOMBRE" required />
            <input type="text" name="lastName" placeholder="APELLIDOS" required />
          </div>
          
          <div class="form-group row">
            <input type="email" name="email" placeholder="CORREO ELECTRÓNICO (Para recibos virtuales)" required />
            <input type="tel" name="phone" placeholder="TELÉFONO DE CONTACTO" required />
          </div>
          
          <div class="form-group">
            <input type="text" name="address" placeholder="DIRECCIÓN DE ENTREGA" required />
          </div>
          
          <div class="form-group row">
            <input type="text" name="city" placeholder="CIUDAD" required />
            <input type="text" name="country" placeholder="PAÍS" required />
          </div>
          
          <div class="form-group">
            <textarea name="notes" placeholder="INSTRUCCIONES ESPECIALES O NOTAS (EJ. 'Es un regalo para...')"></textarea>
          </div>

          <div id="checkout-feedback" class="feedback-msg"></div>
          
          <button type="submit" id="btn-submit-order" class="btn-submit">CONFIRMAR COMPRA <i class="fas fa-arrow-right"></i></button>
        </form>
      </section>

      <!-- Columna Derecha: Resumen -->
      <section class="checkout-summary-section">
        <div class="summary-box">
          <h2 class="summary-title">Resumen de Colección</h2>
          
          <div id="checkout-items" class="checkout-items">
            <!-- Rendered by JS -->
          </div>
          
          <hr class="summary-divider"/>
          
          <div class="summary-row">
            <span>SUBTOTAL</span>
            <span id="checkout-subtotal">U$D 0</span>
          </div>
          <div class="summary-row shipping-row">
            <span>ENVÍO</span>
            <span>A CONVENIR</span>
          </div>
          
          <hr class="summary-divider"/>
          
          <div class="summary-row total-row">
            <span>TOTAL</span>
            <span id="checkout-total">U$D 0</span>
          </div>

          <div class="security-badges">
            <i class="fas fa-lock"></i> Compra Segura Encriptada
            <br/><i class="fas fa-certificate"></i> Incluye Certificado A4 de Autenticidad
          </div>
        </div>
      </section>
      
    </div>
  </main>
  
  <Footer />
</Layout>

<style>
  .checkout-main {
    min-height: 80vh;
    padding: 6rem 5% 8rem;
    max-width: 1400px;
    margin: 0 auto;
    font-family: var(--font-secondary);
  }

  .checkout-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 4rem;
  }

  .checkout-title {
    font-family: var(--font-primary);
    font-size: 2.5rem;
    color: var(--color-white);
    margin: 0 0 0.5rem 0;
    font-weight: 300;
  }

  .checkout-subtitle {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 3rem;
  }

  .checkout-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-group.row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .checkout-form input, .checkout-form textarea {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    color: var(--color-white);
    font-family: var(--font-secondary);
    font-size: 0.8rem;
    padding: 1rem 0;
    outline: none;
    transition: border-color 0.3s;
    letter-spacing: 1px;
  }

  .checkout-form textarea {
    resize: vertical;
    min-height: 80px;
  }

  .checkout-form input:focus, .checkout-form textarea:focus {
    border-color: var(--color-accent);
  }

  .btn-submit {
    margin-top: 2rem;
    background: var(--color-accent);
    color: var(--color-onyx-deep);
    border: none;
    padding: 1.2rem;
    font-family: var(--font-secondary);
    font-weight: 700;
    letter-spacing: 2px;
    font-size: 0.85rem;
    cursor: pointer;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .btn-submit:hover {
    background: var(--color-white);
    transform: translateY(-2px);
  }

  .btn-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* Summary Box */
  .summary-box {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.05);
    padding: 3rem;
    border-radius: 4px;
    position: sticky;
    top: 100px;
  }

  .summary-title {
    font-family: var(--font-primary);
    font-size: 1.5rem;
    color: var(--color-white);
    margin: 0 0 2rem 0;
    font-weight: 300;
    letter-spacing: 1px;
  }

  .summary-divider {
    border-color: rgba(255,255,255,0.05);
    margin: 1.5rem 0;
  }

  .checkout-items {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-height: 300px;
    overflow-y: auto;
  }

  :global(.chk-item) {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  :global(.chk-img) {
    width: 60px;
    height: 80px;
    object-fit: cover;
  }

  :global(.chk-info) {
    flex: 1;
  }

  :global(.chk-info h4) {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--color-white);
  }

  :global(.chk-info p) {
    margin: 0.2rem 0 0;
    font-size: 0.7rem;
    color: var(--color-text-muted);
  }

  :global(.chk-price) {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-white);
  }

  .summary-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    letter-spacing: 1px;
    margin-bottom: 0.8rem;
  }

  .total-row {
    font-size: 1.2rem;
    color: var(--color-white);
    font-weight: 700;
  }

  .security-badges {
    margin-top: 3rem;
    font-size: 0.7rem;
    color: rgba(255,255,255,0.3);
    line-height: 1.8;
    text-align: center;
  }

  .feedback-msg {
    font-size: 0.8rem;
    text-align: center;
    min-height: 1.2rem;
    margin-top: 1rem;
    font-weight: 600;
  }

  @media (max-width: 900px) {
    .checkout-grid {
      grid-template-columns: 1fr;
    }
    .form-group.row {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  import { cartStore, clearCart } from '../store/cartStore';

  document.addEventListener('astro:page-load', () => {
    const listWrapper = document.getElementById('checkout-items');
    const subtotalEl = document.getElementById('checkout-subtotal');
    const totalEl = document.getElementById('checkout-total');
    const form = document.getElementById('checkout-form');
    const btn = document.getElementById('btn-submit-order') as HTMLButtonElement | null;
    const feedback = document.getElementById('checkout-feedback');

    if (!listWrapper || typeof cartStore === 'undefined') return;

    // Load Cart Data
    cartStore.subscribe(cart => {
      const items = Object.values(cart);
      if (items.length === 0) {
        listWrapper.innerHTML = '<p style="font-size: 0.8rem; color: #888;">El carrito está vacío.</p>';
        if (btn) btn.disabled = true;
        if (subtotalEl) subtotalEl.innerText = `U$D 0`;
        if (totalEl) totalEl.innerText = `U$D 0`;
        return;
      }

      listWrapper.innerHTML = items.map(i => `
        <div class="chk-item">
          <img src="${i.image}" class="chk-img" />
          <div class="chk-info">
            <h4>${i.title}</h4>
            <p>${i.size} - Qty: ${i.quantity}</p>
          </div>
          <div class="chk-price">U$D ${i.price * i.quantity}</div>
        </div>
      `).join('');

      const total = items.reduce((sum, i) => sum + (i.price * i.quantity), 0);
      if (subtotalEl) subtotalEl.innerText = `U$D ${total}`;
      if (totalEl) totalEl.innerText = `U$D ${total}`;
    });

    // Form submission simulation
    if (form && btn && feedback) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        
        btn.disabled = true;
        btn.innerHTML = 'PROCESANDO ORDEN...';
        
        // Simulating Backend Order Creation
        setTimeout(() => {
          clearCart();
          form.style.display = 'none';
          document.querySelector('.checkout-subtitle')!.innerHTML = '<strong>¡GRACIAS POR SU COMPRA!</strong> Su solicitud ha sido procesada. En breve, el equipo de logística de Javier Mix se pondrá en contacto para coordinar el pago y el envío asegurado.';
          (document.querySelector('.checkout-title') as HTMLElement).innerText = 'Orden Confirmada';
        }, 1500);
      });
    }
  });
</script>
