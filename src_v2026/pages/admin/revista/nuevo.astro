---
import AdminLayout from '../../../layouts/AdminLayout.astro';

export const prerender = false;
---

<AdminLayout title="Nuevo Artículo - Revista Online">
    <div class="header-actions">
        <div>
            <h2 class="section-title">Redactar Nueva Crónica</h2>
            <p class="section-desc">Crea un nuevo contenido para la audiencia de javiermix.ar</p>
        </div>
        <a href="/admin/revista" class="btn-secondary">
            <i class="fas fa-arrow-left"></i> VOLVER AL LISTADO
        </a>
    </div>

    <div class="panel">
        <form id="new-article-form" class="admin-form">
            <div class="form-grid">
                <!-- Columna Izquierda: Datos Básicos -->
                <div class="form-column">
                    <div class="form-group">
                        <label for="title">Título del Artículo</label>
                        <input type="text" id="title" name="title" placeholder="Ej. El susurro de la arquitectura urbana" required />
                    </div>

                    <div class="form-group">
                        <label for="slug">URL Slug (Identificador único)</label>
                        <div class="input-with-prefix">
                            <span>/revista/</span>
                            <input type="text" id="slug" name="slug" placeholder="el-susurro-urbano" required />
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="tags">Etiquetas (Separadas por comas)</label>
                        <input type="text" id="tags" name="tags" placeholder="arquitectura, b&n, reflexiones" />
                    </div>

                    <div class="form-group">
                        <label for="content_html">Cuerpo del Artículo (HTML Soportado)</label>
                        <textarea id="content_html" name="content_html" rows="18" placeholder="Escribe aquí el contenido en formato HTML..." required></textarea>
                        <small class="hint">Puedes usar etiquetas &lt;p&gt;, &lt;h2&gt;, &lt;strong&gt;, etc. para dar formato.</small>
                    </div>
                </div>

                <!-- Columna Derecha: Media & SEO -->
                <div class="form-column">
                    <div class="form-group">
                        <label for="featured_image">Imagen Principal (Nombre de archivo en /public/uploads/magazine/)</label>
                        <input type="text" id="featured_image" name="featured_image" placeholder="ejemplo.jpg" />
                        <small class="hint">Asegúrate de subir el archivo vía FileBrowser a la carpeta correspondiente.</small>
                    </div>

                    <div class="form-group">
                        <label for="video_url">Video de Fondo (Opcional - MP4)</label>
                        <input type="text" id="video_url" name="video_url" placeholder="video-intro.mp4" />
                    </div>

                    <div class="form-group">
                        <label>Estado de Publicación</label>
                        <select name="status">
                            <option value="published">Publicado</option>
                            <option value="draft">Borrador</option>
                        </select>
                    </div>

                    <div class="form-divider">SEO & Metadatos</div>

                    <div class="form-group">
                        <label for="seo_title">Título SEO (Opcional)</label>
                        <input type="text" id="seo_title" name="seo_title" placeholder="Meta title para Google" />
                    </div>

                    <div class="form-group">
                        <label for="seo_description">Descripción SEO (Opcional)</label>
                        <textarea id="seo_description" name="seo_description" rows="3" placeholder="Resumen corto para resultados de búsqueda"></textarea>
                    </div>

                    <div class="form-group" style="margin-top: 2rem;">
                        <button type="submit" class="btn-primary w-full" id="submit-btn">
                            <i class="fas fa-save"></i> GUARDAR ARTÍCULO
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</AdminLayout>

<style>
    .header-actions {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 3rem;
    }

    .section-title {
        font-size: 1.4rem;
        margin: 0;
        color: white;
        font-weight: 500;
    }

    .section-desc {
        font-size: 0.8rem;
        color: rgba(255,255,255,0.4);
        margin: 5px 0 0;
    }

    .btn-secondary {
        background: rgba(255,255,255,0.05);
        color: white;
        text-decoration: none;
        padding: 0.7rem 1.2rem;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        border: 1px solid rgba(255,255,255,0.1);
        transition: all 0.2s;
    }
    .btn-secondary:hover { background: rgba(255,255,255,0.1); }

    .panel {
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 12px;
        padding: 3rem;
    }

    .admin-form .form-grid {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 4rem;
    }

    .form-group {
        margin-bottom: 2rem;
    }

    .form-group label {
        display: block;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--admin-accent);
        margin-bottom: 0.8rem;
    }

    .form-group input, 
    .form-group textarea, 
    .form-group select {
        width: 100%;
        background: rgba(0,0,0,0.3);
        border: 1px solid rgba(255,255,255,0.1);
        padding: 1rem;
        color: white;
        border-radius: 4px;
        font-family: inherit;
        font-size: 0.9rem;
        box-sizing: border-box;
    }

    .form-group input:focus, 
    .form-group textarea:focus {
        border-color: var(--admin-accent);
        outline: none;
        background: rgba(0,0,0,0.5);
    }

    .input-with-prefix {
        display: flex;
        align-items: center;
        background: rgba(0,0,0,0.3);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 4px;
        overflow: hidden;
    }

    .input-with-prefix span {
        padding: 0 1rem;
        color: rgba(255,255,255,0.3);
        font-size: 0.85rem;
        font-family: monospace;
    }

    .input-with-prefix input {
        border: none;
        background: transparent;
    }

    .hint {
        display: block;
        margin-top: 5px;
        font-size: 0.7rem;
        color: rgba(255,255,255,0.3);
    }

    .form-divider {
        margin: 3rem 0 2rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: rgba(255,255,255,0.2);
    }

    .btn-primary {
        background: var(--admin-accent);
        color: var(--admin-bg);
        border: none;
        padding: 1rem;
        border-radius: 4px;
        font-weight: 700;
        letter-spacing: 1px;
        cursor: pointer;
        transition: all 0.3s;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.8rem;
    }

    .btn-primary:hover { background: white; transform: translateY(-3px); }
    .w-full { width: 100%; }

    @media (max-width: 1024px) {
        .admin-form .form-grid { grid-template-columns: 1fr; gap: 2rem; }
    }
</style>

<script>
    const form = document.getElementById('new-article-form');
    const titleInput = document.getElementById('title') as HTMLInputElement;
    const slugInput = document.getElementById('slug') as HTMLInputElement;

    // Auto-slug generation
    titleInput?.addEventListener('input', () => {
        if (slugInput && !slugInput.value || slugInput.value === slugify(titleInput.value.slice(0, -1))) {
            slugInput.value = slugify(titleInput.value);
        }
    });

    function slugify(text: string) {
        return text.toString().toLowerCase()
            .replace(/\s+/g, '-')           // Replace spaces with -
            .replace(/[^\w\-]+/g, '')       // Remove all non-word chars
            .replace(/\-\-+/g, '-')         // Replace multiple - with single -
            .replace(/^-+/, '')             // Trim - from start of text
            .replace(/-+$/, '');            // Trim - from end of text
    }

    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const submitBtn = document.getElementById('submit-btn');
        if (submitBtn) submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> GUARDANDO...';

        const formData = new FormData(form as HTMLFormElement);
        const data = Object.fromEntries(formData.entries());

        try {
            const res = await fetch('/api/admin/magazine', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            const result = await res.json();
            if (result.success) {
                alert('¡Crónica guardada exitosamente!');
                window.location.href = '/admin/revista';
            } else {
                alert('Error al guardar: ' + result.message);
            }
        } catch (err) {
            alert('Error de conexión con el servidor.');
        } finally {
            if (submitBtn) submitBtn.innerHTML = '<i class="fas fa-save"></i> GUARDAR ARTÍCULO';
        }
    });
</script>
