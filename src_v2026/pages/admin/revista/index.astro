---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { db } from '../../../db/client';
import { magazine } from '../../../db/schema';
import { desc } from 'drizzle-orm';

export const prerender = false;

// Obtener todos los artículos de la revista
const articles = await db.select().from(magazine).orderBy(desc(magazine.created_at));
const formatter = new Intl.DateTimeFormat('es-AR', { dateStyle: 'medium' });
---

<AdminLayout title="Gestión de Revista Online">
    <div class="header-actions">
        <div>
            <h2 class="section-title">Crónicas & Artículos</h2>
            <p class="section-desc">Administra el contenido editorial de la revista javiermix.ar</p>
        </div>
        <a href="/admin/revista/nuevo" class="btn-primary">
            <i class="fas fa-plus"></i> NUEVO ARTÍCULO
        </a>
    </div>

    <div class="panel">
        <div class="panel-body">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Portada</th>
                        <th>Título / Slug</th>
                        <th>Fecha</th>
                        <th>Estado</th>
                        <th>Calificación</th>
                        <th style="text-align: right;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {articles.map((art) => (
                        <tr>
                            <td style="width: 80px;">
                                <div class="art-thumb">
                                    <img src={art.featured_image ? (art.featured_image.startsWith('http') ? art.featured_image : `/uploads/magazine/${art.featured_image}`) : '/img/placeholder.jpg'} alt="" />
                                </div>
                            </td>
                            <td>
                                <div class="art-info-cell">
                                    <span class="art-name">{art.title}</span>
                                    <span class="art-slug">/{art.slug}</span>
                                </div>
                            </td>
                            <td>{art.created_at ? formatter.format(new Date(art.created_at)) : 'N/A'}</td>
                            <td>
                                <span class={`status-badge ${art.status}`}>
                                    {art.status === 'published' ? 'Publicado' : 'Borrador'}
                                </span>
                            </td>
                            <td>
                                <div class="rating-display">
                                    <i class="fas fa-star" style="color: var(--admin-accent);"></i>
                                    <span>{(art.rating_total / (art.rating_count || 1)).toFixed(1)}</span>
                                    <small>({art.rating_count})</small>
                                </div>
                            </td>
                            <td style="text-align: right;">
                                <div class="actions-row-end">
                                    <a href={`/revista/${art.slug}`} target="_blank" class="btn-icon" title="Ver en el sitio">
                                        <i class="fas fa-external-link-alt"></i>
                                    </a>
                                    <a href={`/admin/revista/editar/${art.id}`} class="btn-icon" title="Editar Contenido">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <button class="btn-icon delete-btn" data-id={art.id} title="Eliminar">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    ))}
                    {articles.length === 0 && (
                        <tr>
                            <td colspan="6" style="text-align:center; padding: 4rem; color: rgba(255,255,255,0.3); font-style: italic;">
                                No hay artículos redactados aún. Comienza creando tu primera crónica.
                            </td>
                        </tr>
                    )}
                </tbody>
            </table>
        </div>
    </div>
</AdminLayout>

<style>
    .header-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 3rem;
    }

    .section-title {
        font-size: 1.4rem;
        margin: 0;
        color: white;
        font-weight: 500;
        letter-spacing: 1px;
    }

    .section-desc {
        font-size: 0.8rem;
        color: rgba(255,255,255,0.4);
        margin: 5px 0 0;
    }

    .btn-primary {
        background: var(--admin-accent);
        color: var(--admin-bg);
        border: none;
        padding: 0.9rem 1.8rem;
        border-radius: 4px;
        font-family: var(--font-secondary);
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 2px;
        text-decoration: none;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        gap: 0.8rem;
        box-shadow: 0 4px 15px rgba(189, 155, 83, 0.2);
    }
    .btn-primary:hover {
        background: white;
        transform: translateY(-2px);
    }

    .panel {
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 12px;
        overflow: hidden;
    }

    .admin-table {
        width: 100%;
        border-collapse: collapse;
    }

    .admin-table th, .admin-table td {
        padding: 1.5rem 2rem;
        text-align: left;
        border-bottom: 1px solid rgba(255,255,255,0.03);
    }

    .admin-table th {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: rgba(255,255,255,0.4);
        background: rgba(0,0,0,0.15);
    }

    .art-thumb {
        width: 60px;
        height: 60px;
        border-radius: 4px;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.1);
    }

    .art-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .art-info-cell {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
    }

    .art-name {
        color: white;
        font-weight: 600;
        font-size: 1rem;
    }

    .art-slug {
        font-size: 0.75rem;
        color: var(--admin-accent);
        font-family: monospace;
    }

    .status-badge {
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        padding: 0.3rem 0.6rem;
        border-radius: 4px;
    }

    .status-badge.published { background: rgba(74, 158, 106, 0.1); color: #4a9e6a; }
    .status-badge.draft { background: rgba(255, 255, 255, 0.05); color: #999; }

    .rating-display {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.9rem;
    }

    .rating-display small {
        color: rgba(255,255,255,0.3);
        font-size: 0.7rem;
    }

    .actions-row-end {
        display: flex;
        justify-content: flex-end;
        gap: 0.5rem;
    }

    .btn-icon {
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.05);
        color: rgba(255,255,255,0.6);
        border-radius: 4px;
        text-decoration: none;
        transition: all 0.2s;
        cursor: pointer;
    }

    .btn-icon:hover {
        background: var(--admin-accent);
        color: var(--admin-bg);
        border-color: var(--admin-accent);
    }

    .btn-icon.delete-btn:hover {
        background: #e05555;
        color: white;
        border-color: #e05555;
    }
</style>

<script>
    // Lógica para eliminar artículos
    document.querySelectorAll('.delete-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
            const id = btn.getAttribute('data-id');
            if (confirm('¿Estás seguro de que deseas eliminar esta crónica? Esta acción no se puede deshacer.')) {
                try {
                    const res = await fetch(`/api/admin/magazine?id=${id}`, {
                        method: 'DELETE'
                    });
                    const result = await res.json();
                    if (result.success) {
                        window.location.reload();
                    } else {
                        alert('Error al eliminar: ' + result.message);
                    }
                } catch (err) {
                    alert('Error de conexión.');
                }
            }
        });
    });
</script>
