---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import fs from 'node:fs';
import path from 'node:path';

import { loadArtworkMetadata } from '../utils/metadata.js';

// Leemos las carpetas locales en `public/img/Series`
const seriesPath = path.join(process.cwd(), 'public', 'img', 'Series');
const metadataMap = loadArtworkMetadata();
let seriesList = [];

try {
  if (fs.existsSync(seriesPath)) {
    const folders = fs.readdirSync(seriesPath).filter(file => fs.statSync(path.join(seriesPath, file)).isDirectory());
    
    seriesList = folders.map(folder => {
      const folderPath = path.join(seriesPath, folder);
      const items = fs.readdirSync(folderPath).filter(f => f.endsWith('.avif'));
      
      const mainImages = items.filter(f => {
          const low = f.toLowerCase();
          // Solo los que NO tienen guion bajo seguido de número al final (ej: JMX_9742.avif)
          return (low.startsWith('jmx_') || low.startsWith('jmix_')) && !/_(\d+)\.avif$/.test(low);
      });
      const otherImages = items.filter(f => {
          const low = f.toLowerCase();
          // Los que SÍ tienen guion bajo seguido de número (ej: JMX_9742_2.avif) u otros nombres
          return !mainImages.includes(f);
      });
      
      let matchedOtherImages = new Set();
      mainImages.forEach(mainImg => {
          const baseName = mainImg.split('.')[0].toLowerCase();
          
          // Buscamos JMX_XXXX_2.avif, JMX_XXXX_3.avif, etc.
          const contextImages = otherImages.filter(f => {
              const fLow = f.toLowerCase();
              return fLow.startsWith(baseName + '_') && /_(\d+)\.avif$/.test(fLow);
          });
          
          contextImages.forEach(img => matchedOtherImages.add(img));
      });
      
      const standalone = otherImages.filter(f => !matchedOtherImages.has(f));
      const realCount = mainImages.length + standalone.length;
      
      const firstMain = mainImages.length > 0 ? mainImages[0] : (standalone.length > 0 ? standalone[0] : null);
      const coverImage = firstMain ? `/img/Series/${folder}/${firstMain}` : 'https://placehold.co/800x1200/111/444?text=Sin+Imagen';
      
      const name = folder.split('_').map(word => word.toUpperCase()).join(' ');
      
      return {
        id: folder,
        name: name,
        coverUrl: coverImage,
        count: realCount
      };
    });

    // Filtrar series sin imágenes reales
    seriesList = seriesList.filter(serie => serie.count > 0);
  }
} catch (error) {
  console.error("Error leyendo las series:", error);
}
---

<Layout
  title={`Portfolio · ${seriesList.length} Colecciones Fine Art`}
  description={`Explorá el portfolio completo de Javier Mix: ${seriesList.length} colecciones de fotografía Fine Art de autor. Obras sobre aluminio, impresión de alta calidad, para coleccionistas y decoradores. Buenos Aires.`}
  url="/galeria"
  image={seriesList[0]?.coverUrl}
  keywords={['portfolio fotográfico', 'colecciones de fotografía', 'obras fine art', 'fotografía argentina', ...seriesList.map(s => s.name.toLowerCase())]}
>
    
    <Header currentPath="/galeria" />

	<main class="gallery-container" style="padding-top: 5rem;">
		<header class="gallery-header">
			<h1 class="gallery-title">Fine Art Portfolio</h1>
			<p class="gallery-subtitle">Selección Exclusiva de Obras Disponibles</p>
		</header>

		<!-- 1. Search Bar (Global) -->
		<div class="gallery-search-container" id="gallery-search-overlay">
			<div class="search-input-wrapper" style="position: relative;">
				<input type="text" id="gallery-search-input" placeholder="Buscar por color, tema o título..." aria-label="Buscar obras">
				<button id="gallery-search-btn" style="position: absolute; right: 1.5rem; top: 50%; transform: translateY(-50%); background: none; border: none; color: #fff; cursor: pointer;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                </button>
			</div>
		</div>

		<!-- 2. View Toggle (Series vs All) - DESKTOP ONLY -->
		<div class="gallery-view-toggle">
			<button class="view-toggle-btn active" data-view="series">
				&#9776; Colecciones <!-- Icono de capa fallback -->
			</button>
			<button class="view-toggle-btn inactive" data-view="all">
				&#9638; Ver Todo <!-- Icono de grilla fallback -->
			</button>
		</div>

		<!-- 3. TAB A: SERIES VIEW -->
		<div id="view-series" class="gallery-view active">
			<main class="series-snap-container" style="max-width: 1400px; margin: 0 auto; padding: 0 2rem;">
				{seriesList.length === 0 ? (
					<div class="empty-state">No se encontraron colecciones en public/img/Series</div>
				) : (
					seriesList.map((serie) => (
						<a href={`/galeria/${serie.id}`} class="series-card">
							<div class="series-card-bg" style={`background-image: url('${serie.coverUrl}');`}></div>
							<div class="series-card-content">
								<h2 class="series-title">{serie.name}</h2>
								<p class="series-count">{serie.count} Obras</p>
								<span class="series-cta">Explorar Serie &rarr;</span>
							</div>
						</a>
					))
				)}
			</section>
		</div>
	</main>

	<Footer />
</Layout>

<style>
/* --- Refined styles for the new Design System --- */
.gallery-container {
    background-color: var(--color-onyx-deep);
    min-height: 100vh;
}

.gallery-header {
    text-align: center;
    padding: 6rem 1rem 4rem;
}

.gallery-title {
    font-size: var(--text-h1);
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
    font-family: var(--font-primary);
    color: var(--color-white);
    font-weight: 600;
}

.gallery-subtitle {
    color: var(--color-text-muted);
    font-family: var(--font-secondary);
    font-size: 1.1rem;
    letter-spacing: 1px;
}

/* 1. View Toggle & Search */
.gallery-search-container {
    text-align: center;
    margin: 2rem auto;
    width: 100%;
    max-width: 800px;
    position: relative;
    padding: 0 1rem;
}

#gallery-search-input {
    width: 100%;
    padding: 1.25rem 2rem;
    border-radius: 50px;
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    color: var(--color-white);
    font-family: var(--font-secondary);
    font-size: 1rem;
    backdrop-filter: blur(12px);
    transition: var(--transition-premium);
}

#gallery-search-input:focus {
    background: var(--color-onyx-charcoal);
    border-color: var(--color-accent);
    outline: none;
    box-shadow: 0 0 30px rgba(var(--h-gold), var(--s-gold), 10%);
}

#gallery-search-input::placeholder {
    color: var(--color-text-muted);
}

.gallery-view-toggle {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 4rem;
    width: 100%;
}

.view-toggle-btn {
    background: transparent;
    border: 1px solid var(--glass-border);
    color: var(--color-text-muted);
    padding: 0.75rem 2rem;
    border-radius: 30px;
    cursor: pointer;
    transition: var(--transition-premium);
    font-family: var(--font-secondary);
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 2px;
    font-weight: 600;
}

.view-toggle-btn.active,
.view-toggle-btn:hover {
    background: var(--color-accent);
    color: var(--color-onyx-deep);
    border-color: var(--color-accent);
}

/* 2. Series View Container - DESKTOP GRID */
.series-snap-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); 
    gap: 3rem;
    padding-bottom: 6rem;
}

/* 3. Series Card Design */
.series-card {
    position: relative;
    display: block;
    height: 500px;
    overflow: hidden;
    text-decoration: none;
    transition: var(--transition-premium);
    background-color: var(--color-onyx-charcoal);
}

.series-card-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    transition: transform 1.2s cubic-bezier(0.22, 1, 0.36, 1);
    filter: grayscale(20%) contrast(1.1);
}

.series-card:hover .series-card-bg {
    transform: scale(1.1);
    filter: grayscale(0%) contrast(1.05);
}

.series-card-content {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 3rem;
    background: linear-gradient(to top, var(--color-onyx-deep) 0%, transparent 100%);
    color: var(--color-white);
    transform: translateY(10px);
    transition: var(--transition-premium);
}

.series-card:hover .series-card-content {
    transform: translateY(0);
}

.series-title {
    font-family: var(--font-primary);
    font-size: 2.8rem;
    margin: 0 0 0.5rem 0;
    color: var(--color-white);
    font-weight: 600;
    line-height: 1;
}

.series-count {
    font-family: var(--font-secondary);
    font-size: 0.8rem;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 3px;
    font-weight: 600;
}

.series-cta {
    font-family: var(--font-secondary);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-white);
    opacity: 0; 
    transform: translateX(-10px);
    transition: var(--transition-premium);
    display: inline-block;
    border-bottom: 1px solid var(--color-accent);
    padding-bottom: 4px;
}

.series-card:hover .series-cta {
    opacity: 1;
    transform: translateX(0);
}

/* Mobile Specific: Scroll Snap Restorado! */
@media (max-width: 768px) {
    .series-snap-container {
        display: block;
        height: 75vh;
        overflow-y: scroll;
        scroll-snap-type: y mandatory;
        padding-bottom: 0;
        scrollbar-width: none; /* Hide scrollbar Firefox */
    }
    .series-snap-container::-webkit-scrollbar {
        display: none; /* Hide scrollbar Chrome/Safari */
    }
    .series-card {
        height: 75vh;
        scroll-snap-align: start;
        margin-bottom: 1rem !important;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
    }
    .gallery-view-toggle {
        display: none !important;
    }
    .series-cta {
        opacity: 1; /* Forzar mostrar CTA en táctil donde no hay hover */
        transform: translateX(0);
    }
    .series-card-content {
        transform: translateY(0); /* Forzar estado activo para móvil */
    }
}
</style>

<script>
  // Dynamic Search and View Toggle Logic
  document.addEventListener('astro:page-load', () => {
    const searchInput = document.getElementById('gallery-search-input') as HTMLInputElement;
    const cards = document.querySelectorAll('.series-card');
    const toggleBtns = document.querySelectorAll('.view-toggle-btn');
    
    // 1. Search Logic
    searchInput?.addEventListener('input', (e) => {
      const term = (e.target as HTMLInputElement).value.toLowerCase();
      cards.forEach(card => {
        const title = card.querySelector('.series-title')?.textContent?.toLowerCase() || '';
        const isMatch = title.includes(term);
        (card as HTMLElement).style.display = isMatch ? 'block' : 'none';
      });
    });

    // 2. View Toggle Logic (Placeholder for future "All Works" grid)
    toggleBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        toggleBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        
        const view = btn.getAttribute('data-view');
        console.log(`Cambiando a vista: ${view}`);
        // Implementación de grilla completa próximamente
      });
    });
  });
</script>

