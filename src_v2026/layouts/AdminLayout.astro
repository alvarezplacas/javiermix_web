---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | Admin JHM</title>
    <!-- ══ Google Fonts ══ -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- ══ Font Awesome ══ -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <ClientRouter />
</head>
<body class="admin-body">
    
    <div class="admin-container">
        <!-- Sidebar Inteligente -->
        <aside class="admin-sidebar" transition:persist>
            <div class="sidebar-header">
                <h2 class="admin-brand">JHM</h2>
                <span class="admin-status">OPERATING SYSTEM</span>
            </div>

            <nav class="sidebar-nav">
                <div class="nav-group">
                    <h3>Panel Principal</h3>
                    <a href="/admin" class={currentPath === '/admin' ? 'active' : ''}><i class="fas fa-chart-line"></i> Dashboard</a>
                    <a href="/admin/ventas" class={currentPath.startsWith('/admin/ventas') ? 'active' : ''}><i class="fas fa-shopping-cart"></i> Ventas & Órdenes</a>
                    <a href="/admin/certificados" class={currentPath.startsWith('/admin/certificados') ? 'active' : ''}><i class="fas fa-certificate"></i> Certificados A4</a>
                    <a href="/admin/revista" class={currentPath.startsWith('/admin/revista') ? 'active' : ''}><i class="fas fa-newspaper"></i> Revista Online</a>
                </div>

                <div class="nav-group">
                    <h3>Ecosistema Externo</h3>
                    <a href="https://admin.javiermix.ar" target="_blank"><i class="fas fa-database"></i> Directus (Base de Datos) <i class="fas fa-external-link-alt ext-icon"></i></a>
                    <a href="https://stats.javiermix.ar" target="_blank"><i class="fas fa-chart-pie"></i> Umami (Métricas) <i class="fas fa-external-link-alt ext-icon"></i></a>
                    <a href="https://files.javiermix.ar" target="_blank"><i class="fas fa-folder-open"></i> FileBrowser (Nube) <i class="fas fa-external-link-alt ext-icon"></i></a>
                </div>
            </nav>

            <div class="sidebar-footer">
                <a href="/" class="btn-exit"><i class="fas fa-sign-out-alt"></i> Salir al Sitio Web</a>
            </div>
        </aside>

        <!-- Contenido Dinámico -->
        <main class="admin-content">
            <header class="content-header">
                <h1>{title}</h1>
                <div class="header-user">
                    <img src="/img/avatars/jhmix.jpg" onerror="this.src='data:image/svg+xml;utf8,<svg xmlns=\'http://www.w3.org/2000/svg\' viewBox=\'0 0 100 100\'><rect width=\'100\' height=\'100\' fill=\'%23bd9b53\'/></svg>'" alt="Javier M." class="user-avatar" />
                    <span>Javier Mix</span>
                </div>
            </header>
            
            <div class="content-body">
                <slot />
            </div>
        </main>
    </div>

</body>
</html>

<style is:global>
    :root {
        --admin-bg: #090a0d;
        --admin-sidebar: #12141a;
        --admin-border: rgba(255,255,255,0.05);
        --admin-text: #e0e0e0;
        --admin-accent: #bd9b53;
    }

    body.admin-body {
        background-color: var(--admin-bg);
        color: var(--admin-text);
        margin: 0;
        font-family: var(--font-secondary);
    }

    .admin-container {
        display: flex;
        min-height: 100vh;
    }

    /* Sidebar */
    .admin-sidebar {
        width: 300px;
        background-color: var(--admin-sidebar);
        border-right: 1px solid var(--admin-border);
        display: flex;
        flex-direction: column;
        position: fixed;
        height: 100vh;
        z-index: 100;
    }

    .sidebar-header {
        padding: 2.5rem 2rem;
        border-bottom: 1px solid var(--admin-border);
    }

    .admin-brand {
        font-family: var(--font-primary);
        font-size: 2.5rem;
        font-style: italic;
        color: var(--admin-accent);
        margin: 0;
        letter-spacing: 2px;
    }

    .admin-status {
        font-size: 0.6rem;
        letter-spacing: 3px;
        color: rgba(255,255,255,0.3);
        margin-top: 5px;
        display: block;
    }

    .sidebar-nav {
        flex: 1;
        padding: 2rem;
        overflow-y: auto;
    }

    .nav-group {
        margin-bottom: 2.5rem;
    }

    .nav-group h3 {
        font-size: 0.65rem;
        letter-spacing: 2px;
        color: rgba(255,255,255,0.4);
        text-transform: uppercase;
        margin-bottom: 1rem;
    }

    .nav-group a {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.8rem 1rem;
        color: rgba(255,255,255,0.7);
        text-decoration: none;
        font-size: 0.85rem;
        border-radius: 6px;
        transition: all 0.3s;
        margin-bottom: 0.2rem;
    }

    .nav-group a i {
        width: 20px;
        text-align: center;
        font-size: 1rem;
    }

    .nav-group a .ext-icon {
        font-size: 0.6rem;
        margin-left: auto;
        opacity: 0.5;
    }

    .nav-group a:hover, .nav-group a.active {
        background: rgba(189, 155, 83, 0.1);
        color: var(--admin-accent);
    }

    .sidebar-footer {
        padding: 2rem;
        border-top: 1px solid var(--admin-border);
    }

    .btn-exit {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        color: rgba(255,255,255,0.4);
        text-decoration: none;
        font-size: 0.8rem;
        transition: color 0.3s;
    }
    .btn-exit:hover { color: #e05555; }

    /* Content Area */
    .admin-content {
        flex: 1;
        margin-left: 300px;
        display: flex;
        flex-direction: column;
    }

    .content-header {
        height: 100px;
        border-bottom: 1px solid var(--admin-border);
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0 4rem;
        background: var(--admin-bg);
        position: sticky;
        top: 0;
        z-index: 90;
    }

    .content-header h1 {
        font-family: var(--font-primary);
        font-size: 1.8rem;
        margin: 0;
        font-weight: 400;
        color: white;
    }

    .header-user {
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 0.85rem;
        color: rgba(255,255,255,0.8);
    }

    .user-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid var(--admin-accent);
    }

    .content-body {
        padding: 4rem;
        max-width: 1400px;
    }
</style>
