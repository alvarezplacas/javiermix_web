---
// src/components/MagazineSection.astro
const articles = [
  {
    title: "Cartógrafo de lo Invisible",
    excerpt: "Navegando las fronteras entre la sombra y la memoria. Una exploración profunda sobre la arquitectura industrial de Milán y su diálogo con el silencio contemporáneo.",
    image: "/img/magazine/milan.png",
    readTime: "8 min",
    link: "/revista/cartografo-de-lo-invisible",
    location: "Milán, Italia"
  },
  {
    title: "La Luz en el Interior",
    excerpt: "Cómo la luz natural transforma el espacio habitado. Un ensayo visual sobre la potencia de la iluminación en el diseño de interiores y la fotografía de autor.",
    image: "/img/magazine/interior.png",
    readTime: "6 min",
    link: "/revista/la-luz-en-el-interior",
    location: "Estudio Javier Mix"
  }
];
---

<section class="magazine-section">
  <header class="section-header reveal">
    <h2 class="section-title">REVISTA DIGITAL</h2>
    <p class="section-subtitle">Crónicas de luz, memoria y potencia estética en la vanguardia contemporánea.</p>
  </header>

  <div class="articles-container">
    {articles.map((article, index) => (
      <article class={`magazine-card ${index % 2 === 0 ? 'row' : 'row-reverse'} reveal`}>
        <div class="card-image-wrapper">
          <div class="tilt-container">
            <img src={article.image} alt={article.title} class="article-image" loading="lazy" />
          </div>
        </div>
        
        <div class="card-content-block">
          <span class="article-location">{article.location}</span>
          <h3 class="article-title">{article.title}</h3>
          <p class="article-excerpt">{article.excerpt}</p>
          
          <div class="article-meta">
            <div class="time-indicator">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="clock-icon">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
              <span>{article.readTime} LECTURA</span>
            </div>
            
            <a href={article.link} class="btn-read-premium">
              <span class="btn-label">LEER NOTA</span>
              <span class="btn-line"></span>
            </a>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .magazine-section {
    padding: 10rem 5%;
    background-color: var(--color-onyx-deep);
    position: relative;
    overflow: hidden;
  }

  .section-header {
    text-align: center;
    margin-bottom: 8rem;
    max-width: 800px;
    margin-inline: auto;
  }

  .section-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    letter-spacing: 12px;
    font-weight: 300;
    margin-bottom: 1.5rem;
    color: var(--color-white);
  }

  .section-subtitle {
    color: var(--color-text-muted);
    font-family: var(--font-secondary);
    font-size: 0.9rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    line-height: 1.6;
  }

  .articles-container {
    max-width: var(--container-max);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 15rem; /* Large gap between articles */
  }

  .magazine-card {
    display: flex;
    align-items: center;
    gap: 8%;
    position: relative;
  }

  .magazine-card.row { flex-direction: row; }
  .magazine-card.row-reverse { flex-direction: row-reverse; }

  /* Image Side */
  .card-image-wrapper {
    flex: 0 0 50%;
    position: relative;
    z-index: 1;
  }

  .tilt-container {
    position: relative;
    width: 100%;
    height: 550px;
    background-color: var(--color-onyx-charcoal);
    box-shadow: 0 30px 60px rgba(0,0,0,0.5);
    perspective: 1000px;
    overflow: hidden;
  }

  .article-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    filter: grayscale(20%) brightness(0.9);
  }

  .magazine-card:hover .article-image {
    transform: scale(1.05);
    filter: grayscale(0%) brightness(1);
  }

  /* Content Block */
  .card-content-block {
    flex: 1;
    padding: 4rem;
    background: rgba(17, 17, 17, 0.6);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.05);
    position: relative;
    z-index: 2;
    margin-left: -5%; /* Overlap effect */
  }

  .row-reverse .card-content-block {
    margin-left: 0;
    margin-right: -5%;
  }

  .article-location {
    color: var(--color-accent);
    font-size: 0.75rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    font-weight: 700;
    margin-bottom: 2rem;
    display: block;
  }

  .article-title {
    font-size: clamp(2rem, 3vw, 3rem);
    font-family: var(--font-primary);
    line-height: 1.1;
    margin-bottom: 2rem;
    color: var(--color-white);
  }

  .article-excerpt {
    color: var(--color-travertine-light);
    font-size: 1rem;
    line-height: 1.8;
    margin-bottom: 3rem;
    max-width: 90%;
  }

  .article-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-top: 2rem;
  }

  .time-indicator {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-text-muted);
    font-size: 0.75rem;
    letter-spacing: 2px;
  }

  .clock-icon {
    width: 14px;
    height: 14px;
    color: var(--color-accent);
  }

  /* Premium Button */
  .btn-read-premium {
    position: relative;
    display: inline-flex;
    flex-direction: column;
    color: var(--color-white);
    text-decoration: none;
    font-weight: 700;
    letter-spacing: 3px;
    font-size: 0.8rem;
    transition: var(--transition-premium);
  }

  .btn-line {
    width: 30px;
    height: 2px;
    background-color: var(--color-accent);
    margin-top: 8px;
    transition: width 0.4s ease;
  }

  .btn-read-premium:hover .btn-label {
    color: var(--color-accent);
  }

  .btn-read-premium:hover .btn-line {
    width: 100%;
  }

  /* Reveal animations */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: all 1.2s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 1024px) {
    .magazine-card {
      flex-direction: column !important;
      gap: 0;
    }
    .card-image-wrapper {
      width: 100%;
      flex: none;
    }
    .card-content-block {
      width: 90%;
      margin: -50px auto 0 !important;
      padding: 2.5rem;
    }
    .articles-container {
      gap: 5rem;
    }
    .tilt-container {
      height: 400px;
    }
  }
</style>

<script>
  // Subtle Scroll Reveal & Mouse Tilt
  document.addEventListener('astro:page-load', () => {
    const reveals = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.1 });

    reveals.forEach(r => observer.observe(r));

    // Subtle Tilt effect for cards
    const containers = document.querySelectorAll('.tilt-container');
    containers.forEach(container => {
      container.addEventListener('mousemove', (e) => {
        const { left, top, width, height } = container.getBoundingClientRect();
        const x = (e.clientX - left) / width - 0.5;
        const y = (e.clientY - top) / height - 0.5;
        
        const img = container.querySelector('img');
        if (img) {
          img.style.transform = `scale(1.08) rotateY(${x * 10}deg) rotateX(${y * -10}deg)`;
        }
      });

      container.addEventListener('mouseleave', () => {
        const img = container.querySelector('img');
        if (img) {
          img.style.transform = 'scale(1) rotateY(0) rotateX(0)';
        }
      });
    });
  });
</script>
