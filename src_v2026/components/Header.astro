---
// src/components/Header.astro
const { currentPath = '/', theme = 'dark' } = Astro.props;
---

<header class={`site-header theme-${theme}`}>
	<nav class="nav-container" aria-label="Navegación principal">
		<a href="/" class="nav-logo" aria-label="Ir al Inicio">
			<span class="brand-name">Javier Mix</span>
		</a>
		<div class="nav-links">
			<a href="/" class={currentPath === '/' ? 'active' : ''}>Inicio</a>
			<a href="/galeria" class={currentPath.startsWith('/galeria') ? 'active' : ''}>Colección</a>
			<a href="/revista" class={currentPath.startsWith('/revista') ? 'active' : ''}>Revista</a>
			<a href="/enmarcado" class={currentPath.startsWith('/enmarcado') ? 'active' : ''}>Studio Enmarcado</a>
		</div>
	</nav>
</header>

<style>
/* Estilos Scoped Puros del Header Modular */
.site-header {
	position: sticky;
	top: 0;
	z-index: 1000;
	background-color: var(--glass-bg);
	backdrop-filter: blur(12px);
	-webkit-backdrop-filter: blur(12px);
	border-bottom: 1px solid var(--glass-border);
	padding: 1rem 0;
	width: 100%;
	transition: var(--transition-premium);
}

.nav-container {
	max-width: var(--container-max);
	margin: 0 auto;
	padding: 0 5%;
	display: flex;
	justify-content: space-between;
	align-items: center;
}

.brand-name {
	font-family: var(--font-primary);
	font-size: 2rem;
	font-weight: 500;
	font-style: italic;
	color: var(--color-white);
	text-transform: capitalize; /* Cambiamos a capitales para más "carácter" de firma */
	letter-spacing: 2px;
	transition: var(--transition-premium);
	display: block;
	white-space: nowrap;
	text-shadow: 2px 2px 10px rgba(0,0,0,0.3);
}

.nav-logo:hover .brand-name {
	color: var(--color-accent);
	transform: skewX(-5deg); /* Aumentamos ligeramente la inclinación al hover */
	letter-spacing: 4px;
}

.nav-links {
	display: flex;
	gap: 2.5rem;
	font-family: var(--font-secondary);
	font-size: 0.8rem;
	text-transform: uppercase;
	letter-spacing: 2px;
    font-weight: 600;
}

.nav-links a {
	color: var(--color-text-muted);
	text-decoration: none;
	transition: var(--transition-premium);
	position: relative;
	padding: 0.5rem 0;
}

.nav-links a:hover, 
.nav-links a.active {
	color: var(--color-white);
}

.nav-links a::after {
	content: '';
	position: absolute;
	bottom: 0;
	left: 0;
	width: 0;
	height: 1px;
	background-color: var(--color-accent);
	transition: var(--transition-premium);
}

.nav-links a:hover::after,
.nav-links a.active::after {
	width: 100%;
}

@media (max-width: 768px) {
    .nav-links {
        display: none;
    }
}
</style>
