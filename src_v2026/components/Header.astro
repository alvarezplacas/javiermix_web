---
// src/components/Header.astro
const { currentPath = '/', theme = 'dark' } = Astro.props;
---

<header class={`site-header theme-${theme}`}>
	<nav class="nav-container" aria-label="Navegación principal">
		<a href="/" class="nav-logo" aria-label="Ir al Inicio">
			<span class="brand-name">JHM</span>
		</a>
		<div class="nav-links">
			<a href="/" class={currentPath === '/' ? 'active' : ''}>Inicio</a>
			<a href="/galeria" class={currentPath.startsWith('/galeria') ? 'active' : ''}>Colección</a>
 			<a href="/revista" class={currentPath.startsWith('/revista') ? 'active' : ''}>Revista</a>
 			<a href="/enmarcado" class={currentPath.startsWith('/enmarcado') ? 'active' : ''}>Studio Enmarcado</a>
            {currentPath.startsWith('/admin') && (
                <a href="/admin/obras" class={currentPath.startsWith('/admin/obras') ? 'active' : ''}>Gestionar Obras</a>
            )}
			<button id="nav-cart-btn" class="nav-cart-btn" aria-label="Ver Carrito">
				<i class="fas fa-shopping-bag"></i>
				<span id="cart-count-badge" class="cart-badge" style="display: none;">0</span>
			</button>
		</div>
	</nav>
</header>

<style>
/* Estilos Scoped Puros del Header Modular */
.site-header {
	position: sticky;
	top: 0;
	z-index: 1000;
	background-color: var(--glass-bg);
	backdrop-filter: blur(12px);
	-webkit-backdrop-filter: blur(12px);
	border-bottom: 1px solid var(--glass-border);
	padding: 1rem 0;
	width: 100%;
	transition: var(--transition-premium);
}

.nav-container {
	max-width: var(--container-max);
	margin: 0 auto;
	padding: 0 5%;
	display: flex;
	justify-content: space-between;
	align-items: center;
}

.brand-name {
	font-family: var(--font-primary);
	font-size: 2.2rem; /* Slightly larger for shorter acronym */
	font-weight: 500;
	font-style: italic;
	color: var(--color-white);
	text-transform: uppercase;
	letter-spacing: 4px; /* Increased spacing */
	transition: var(--transition-premium);
	display: block;
	white-space: nowrap;
	text-shadow: 2px 2px 10px rgba(0,0,0,0.3);
}

.nav-logo:hover .brand-name {
	color: var(--color-accent);
	transform: skewX(-5deg); /* Aumentamos ligeramente la inclinación al hover */
	letter-spacing: 4px;
}

.nav-links {
	display: flex;
	gap: 2.5rem;
	font-family: var(--font-secondary);
	font-size: 0.8rem;
	text-transform: uppercase;
	letter-spacing: 2px;
    font-weight: 600;
}

.nav-links a {
	color: var(--color-text-muted);
	text-decoration: none;
	transition: var(--transition-premium);
	position: relative;
	padding: 0.5rem 0;
}

.nav-links a:hover, 
.nav-links a.active {
	color: var(--color-white);
}

.nav-cart-btn {
	background: transparent;
	border: none;
	color: var(--color-text-muted);
	font-size: 1.1rem;
	cursor: pointer;
	position: relative;
	transition: var(--transition-premium);
	padding: 0;
	display: flex;
	align-items: center;
}

.nav-cart-btn:hover {
	color: var(--color-accent);
}

.cart-badge {
	position: absolute;
	top: -6px;
	right: -8px;
	background-color: var(--color-accent);
	color: var(--color-onyx-deep);
	font-size: 0.6rem;
	font-weight: 700;
	width: 16px;
	height: 16px;
	border-radius: 50%;
	display: flex;
	justify-content: center;
	align-items: center;
	font-family: var(--font-secondary);
}

.nav-links a::after {
	content: '';
	position: absolute;
	bottom: 0;
	left: 0;
	width: 0;
	height: 1px;
	background-color: var(--color-accent);
	transition: var(--transition-premium);
}

.nav-links a:hover::after,
.nav-links a.active::after {
	width: 100%;
}

@media (max-width: 768px) {
    .nav-links {
        display: none;
    }
}
</style>
