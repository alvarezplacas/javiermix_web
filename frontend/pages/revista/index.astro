---
// h:\Javiermix_web_v2\frontend\magazine\index.astro
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
const PUBLIC_DIRECTUS_URL = process.env.PUBLIC_DIRECTUS_URL || 'https://admin.javiermix.ar';
const INTERNAL_DIRECTUS_URL = process.env.INTERNAL_DIRECTUS_URL || PUBLIC_DIRECTUS_URL;

// Fetch articles from Directus API
let dbArticles = [];
try {
  const response = await fetch(`${INTERNAL_DIRECTUS_URL}/items/magazine?sort=-created_at`);
  const data = await response.json();
  dbArticles = data.data || [];
} catch (e) {
  console.error("Error fetching magazine articles via API:", e);
}

function resolveMediaURL(url: string | null): string {
  if (!url) return '/img/placeholder.jpg';
  
  // Si hay múltiples nombres separados por coma, tomar el primero
  const cleanUrl = url.includes(',') ? url.split(',')[0].trim() : url;
  
  if (cleanUrl.startsWith('http') || cleanUrl.startsWith('/')) return cleanUrl;
  
  // Directus UUID support
  if (cleanUrl.length === 36 && cleanUrl.includes('-')) {
    return `${PUBLIC_DIRECTUS_URL}/assets/${cleanUrl}`;
  }
  
  // Legacy Filezilla upload fallback
  return `/uploads/revista/${cleanUrl}`;
}

const articles = dbArticles.map(art => {
  const wordCount = art.content_html.replace(/<[^>]*>/g, '').split(/\s+/).length;
  const readTime = Math.max(1, Math.ceil(wordCount / 200));

  return {
    title: art.title,
    excerpt: art.content_html.replace(/<[^>]*>/g, '').substring(0, 180) + '...',
    image: resolveMediaURL(art.featured_image),
    readTime: `${readTime} min`,
    link: `/revista/${art.slug}`,
    location: "Buenos Aires",
    category: art.tags ? art.tags.split(',')[0].trim() : "Ensayo Visual"
  };
});
---

<Layout
  title="Revista Digital de Fotografía Fine Art"
  description="Artículos, ensayos visuales y crónicas sobre fotografía de autor, diseño de interiores y el arte de coleccionar imágenes."
  url="/revista"
>
  <Header currentPath="/revista" />

  <main class="revista-main">
    <div class="revista-hero">
      <div class="hero-bg-line"></div>
      <span class="issue-tag">Vol. I · 2026</span>
      <h1 class="revista-title">REVISTA DIGITAL</h1>
      <p class="revista-subtitle">Crónicas de luz, memoria y potencia estética para coleccionistas y decoradores.</p>
    </div>

    <div class="articles-wrapper">
      {articles.length > 0 ? (
        articles.map((article, index) => (
          <article class={`article-row ${index % 2 !== 0 ? 'reversed' : ''}`}>
            <div class="article-visual">
              <div class="tilt-frame">
                <img src={article.image} alt={article.title} class="article-img" loading="lazy" />
                <div class="image-glare"></div>
              </div>
              <span class="category-tag">{article.category}</span>
            </div>

            <div class="article-text">
              <span class="article-location">{article.location}</span>
              <h2 class="article-headline">{article.title}</h2>
              <p class="article-excerpt">{article.excerpt}</p>

              <footer class="article-footer">
                <div class="read-time">
                  <span>{article.readTime} de lectura</span>
                </div>
                <a href={article.link} class="btn-leer">
                  LEER NOTA
                  <span class="btn-underline"></span>
                </a>
              </footer>
            </div>
          </article>
        ))
      ) : (
        <div class="empty-state">
           <p>Próximamente nuevas crónicas y ensayos visuales.</p>
        </div>
      )}
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .revista-main { background-color: var(--color-onyx-deep); min-height: 100vh; padding-top: 5rem; }
  .revista-hero { text-align: center; padding: 8rem 2rem 6rem; position: relative; border-bottom: 1px solid rgba(255,255,255,0.05); }
  .hero-bg-line { position: absolute; left: 50%; top: 0; width: 1px; height: 100%; background: linear-gradient(to bottom, transparent, var(--color-accent), transparent); opacity: 0.3; transform: translateX(-50%); }
  .issue-tag { display: inline-block; font-size: 0.7rem; letter-spacing: 4px; text-transform: uppercase; color: var(--color-accent); margin-bottom: 2rem; border: 1px solid rgba(220, 177, 74, 0.3); padding: 0.4rem 1.2rem; }
  .revista-title { font-size: clamp(3rem, 8vw, 7rem); font-weight: 300; letter-spacing: 10px; color: #fff; margin-bottom: 2rem; }
  .articles-wrapper { max-width: 1400px; margin: 0 auto; padding: 8rem 5%; display: flex; flex-direction: column; gap: 12rem; }
  .article-row { display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center; }
  .article-row.reversed { direction: rtl; }
  .article-row.reversed > * { direction: ltr; }
  .article-visual { position: relative; }
  .tilt-frame { width: 100%; height: 500px; overflow: hidden; position: relative; background: #111; box-shadow: 0 40px 80px rgba(0,0,0,0.6); }
  .article-img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(30%) brightness(0.85); transition: transform 0.8s ease; }
  .tilt-frame:hover .article-img { transform: scale(1.06); filter: grayscale(0%) brightness(1); }
  .category-tag { position: absolute; bottom: -1rem; left: 2rem; background: var(--color-accent); color: #000; font-size: 0.65rem; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; padding: 0.5rem 1.2rem; }
  .article-text { padding: 2rem 0; }
  .article-location { display: block; font-size: 0.7rem; letter-spacing: 4px; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-bottom: 1.5rem; }
  .article-headline { font-size: clamp(2.5rem, 4vw, 3.5rem); font-weight: 400; font-style: italic; color: #fff; line-height: 1.1; margin-bottom: 2rem; font-family: var(--font-primary); }
  .article-excerpt { color: rgba(255,255,255,0.5); font-size: 0.9rem; line-height: 1.9; margin-bottom: 3rem; }
  .article-footer { display: flex; justify-content: space-between; align-items: center; border-top: 1px solid rgba(255,255,255,0.08); padding-top: 2rem; }
  .read-time { color: rgba(255,255,255,0.4); font-size: 0.75rem; letter-spacing: 2px; text-transform: uppercase; }
  .btn-leer { position: relative; color: #fff; font-size: 0.75rem; font-weight: 700; letter-spacing: 3px; }
  .btn-underline { display: block; width: 30%; height: 1px; background-color: var(--color-accent); margin-top: 6px; transition: width 0.4s ease; }
  .btn-leer:hover .btn-underline { width: 100%; }
  @media (max-width: 900px) {
    .article-row { grid-template-columns: 1fr; gap: 3rem; direction: ltr !important; }
    .articles-wrapper { gap: 6rem; }
    .tilt-frame { height: 350px; }
  }
</style>
